{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "name": "fine-tuning.status",
  "description": "Get the status and progress of a fine-tuning job.",
  "inputSchema": {
    "type": "object",
    "properties": {
      "job_id": {
        "type": "string",
        "description": "Fine-tuning job identifier"
      }
    },
    "required": ["job_id"]
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "job_id": {
        "type": "string"
      },
      "status": {
        "type": "string",
        "enum": ["PENDING", "RUNNING", "COMPLETED", "FAILED", "CANCELLED"]
      },
      "progress": {
        "type": "object",
        "properties": {
          "epoch": {
            "type": "integer"
          },
          "step": {
            "type": "integer"
          },
          "total_steps": {
            "type": "integer"
          },
          "loss": {
            "type": "number"
          },
          "accuracy": {
            "type": "number"
          }
        }
      },
      "model_registry": {
        "type": "object",
        "properties": {
          "model_id": {
            "type": "string"
          },
          "deployed": {
            "type": "boolean"
          },
          "deployment_url": {
            "type": "string"
          }
        }
      }
    },
    "required": ["job_id", "status"]
  }
}
