{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "name": "agentRegistry.deprecate",
  "description": "Deprecate an agent, changing its status to DEPRECATED. Requires a reason and optional replacement agent.",
  "inputSchema": {
    "type": "object",
    "properties": {
      "agent_id": {
        "type": "string",
        "description": "Unique agent identifier"
      },
      "reason": {
        "type": "string",
        "description": "Reason for deprecation"
      },
      "replacement_id": {
        "type": "string",
        "description": "Optional: agent ID of the replacement"
      },
      "actor_id": {
        "type": "string",
        "description": "User ID performing the deprecation"
      }
    },
    "required": ["agent_id", "reason", "actor_id"]
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "agent_id": {
        "type": "string"
      },
      "name": {
        "type": "string"
      },
      "description": {
        "type": "string"
      },
      "mission": {
        "type": "string"
      },
      "role_alignment": {
        "type": "string",
        "enum": ["STRATEGIST", "TEACHER", "STUDENT"]
      },
      "status": {
        "type": "string",
        "enum": ["DEPRECATED"],
        "description": "Always DEPRECATED after successful deprecation"
      },
      "visibility": {
        "type": "string",
        "enum": ["PRIVATE", "TEAM", "ORG", "PUBLIC"]
      },
      "version": {
        "type": "integer"
      },
      "capabilities": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "default_behaviors": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "tags": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "builtin": {
        "type": "boolean"
      },
      "owner_id": {
        "type": "string"
      },
      "created_at": {
        "type": "string",
        "format": "date-time"
      },
      "updated_at": {
        "type": "string",
        "format": "date-time"
      },
      "published_at": {
        "type": "string",
        "format": "date-time"
      },
      "deprecated_at": {
        "type": "string",
        "format": "date-time",
        "description": "Timestamp when the agent was deprecated"
      },
      "deprecated_reason": {
        "type": "string",
        "description": "Reason for deprecation"
      },
      "replacement_agent_id": {
        "type": "string",
        "description": "ID of the replacement agent, if specified"
      },
      "metadata": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "required": ["agent_id", "name", "status", "deprecated_at", "deprecated_reason"]
  }
}
