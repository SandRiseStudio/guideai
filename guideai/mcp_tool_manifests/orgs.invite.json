{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "name": "orgs.invite",
  "description": "Invite a user to an organization. Requires admin or owner role.",
  "inputSchema": {
    "type": "object",
    "properties": {
      "org_id": {
        "type": "string",
        "description": "Organization ID to invite to"
      },
      "email": {
        "type": "string",
        "format": "email",
        "description": "Email address of user to invite"
      },
      "role": {
        "type": "string",
        "enum": ["admin", "member", "viewer"],
        "default": "member",
        "description": "Role to assign (owners cannot be invited, only transferred)"
      },
      "projects": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "description": "Optional project IDs to grant access to"
      },
      "message": {
        "type": "string",
        "maxLength": 500,
        "description": "Custom message to include in invitation email"
      }
    },
    "required": ["org_id", "email"]
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "invitation_id": {
        "type": "string",
        "description": "Unique invitation ID"
      },
      "email": {
        "type": "string"
      },
      "role": {
        "type": "string"
      },
      "expires_at": {
        "type": "string",
        "format": "date-time",
        "description": "Invitation expiry (default 7 days)"
      },
      "status": {
        "type": "string",
        "enum": ["pending", "accepted", "expired", "revoked"]
      }
    }
  }
}
