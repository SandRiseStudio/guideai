{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "name": "board.createLabel",
  "description": "Create a new label for a project. Labels are used to categorize and filter work items.",
  "inputSchema": {
    "type": "object",
    "required": ["project_id", "name"],
    "properties": {
      "project_id": {
        "type": "string",
        "description": "ID of the project to create the label in"
      },
      "name": {
        "type": "string",
        "description": "Label name (must be unique within project)",
        "minLength": 1,
        "maxLength": 50
      },
      "color": {
        "type": "string",
        "enum": ["gray", "red", "orange", "yellow", "green", "teal", "blue", "indigo", "purple", "pink"],
        "description": "Label color (defaults to gray)",
        "default": "gray"
      },
      "org_id": {
        "type": "string",
        "description": "Optional organization ID for multi-tenant context"
      },
      "actor": {
        "type": "object",
        "description": "Optional actor context for audit logging",
        "properties": {
          "id": {
            "type": "string",
            "description": "Actor ID"
          },
          "type": {
            "type": "string",
            "enum": ["user", "agent", "system"],
            "description": "Actor type"
          }
        }
      }
    }
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "label": {
        "type": "object",
        "description": "The created label",
        "properties": {
          "id": {
            "type": "string",
            "description": "Label ID"
          },
          "name": {
            "type": "string",
            "description": "Label name"
          },
          "color": {
            "type": "string",
            "description": "Label color"
          },
          "project_id": {
            "type": "string",
            "description": "Project ID"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    }
  }
}
