{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "name": "boards.list",
  "description": "List boards for a project. Returns all boards within the specified project.",
  "inputSchema": {
    "type": "object",
    "properties": {
      "project_id": {
        "type": "string",
        "description": "Project ID to list boards for (required)"
      },
      "org_id": {
        "type": "string",
        "description": "Optional organization ID for multi-tenant context"
      },
      "limit": {
        "type": "integer",
        "default": 50,
        "minimum": 1,
        "maximum": 100,
        "description": "Maximum number of boards to return"
      },
      "offset": {
        "type": "integer",
        "default": 0,
        "minimum": 0,
        "description": "Number of boards to skip for pagination"
      }
    },
    "required": ["project_id"]
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "success": { "type": "boolean" },
      "boards": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "board_id": { "type": "string" },
            "project_id": { "type": "string" },
            "name": { "type": "string" },
            "description": { "type": "string" },
            "is_default": { "type": "boolean" },
            "created_at": { "type": "string", "format": "date-time" },
            "updated_at": { "type": "string", "format": "date-time" }
          }
        }
      },
      "total": { "type": "integer" },
      "project_id": { "type": "string" },
      "limit": { "type": "integer" },
      "offset": { "type": "integer" }
    }
  }
}
