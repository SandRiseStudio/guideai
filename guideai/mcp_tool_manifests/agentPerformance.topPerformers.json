{
  "name": "agentPerformance.topPerformers",
  "description": "Get a ranked list of top performing agents based on a specified metric. Useful for identifying high-performing agents and best practices.",
  "inputSchema": {
    "type": "object",
    "properties": {
      "metric": {
        "type": "string",
        "description": "Metric to rank by: success_rate, token_savings, behavior_reuse, compliance_coverage, utilization",
        "enum": ["success_rate", "token_savings", "behavior_reuse", "compliance_coverage", "utilization"],
        "default": "success_rate"
      },
      "limit": {
        "type": "integer",
        "description": "Maximum number of agents to return (default: 10)",
        "default": 10,
        "minimum": 1,
        "maximum": 100
      },
      "period_days": {
        "type": "integer",
        "description": "Number of days to analyze (default: 30)",
        "default": 30,
        "minimum": 1,
        "maximum": 365
      },
      "org_id": {
        "type": "string",
        "description": "Optional organization filter"
      },
      "min_tasks": {
        "type": "integer",
        "description": "Minimum tasks required to qualify (default: 5)",
        "default": 5,
        "minimum": 1
      }
    }
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "metric": {
        "type": "string",
        "description": "Metric used for ranking"
      },
      "period_days": {
        "type": "integer",
        "description": "Analysis period in days"
      },
      "performers": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "rank": {
              "type": "integer",
              "description": "Ranking position"
            },
            "agent_id": {
              "type": "string",
              "description": "Agent identifier"
            },
            "total_tasks": {
              "type": "integer",
              "description": "Total tasks completed"
            },
            "success_rate_pct": {
              "type": "number",
              "description": "Success rate percentage"
            },
            "token_savings_pct": {
              "type": "number",
              "description": "Token savings percentage"
            },
            "behavior_reuse_pct": {
              "type": "number",
              "description": "Behavior reuse percentage"
            },
            "compliance_coverage_pct": {
              "type": "number",
              "description": "Compliance coverage percentage"
            }
          }
        },
        "description": "List of top performing agents"
      }
    }
  }
}
