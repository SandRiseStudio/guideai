{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "name": "billing.cancelSubscription",
  "description": "Cancel an organization's subscription. By default, cancels at end of current period.",
  "inputSchema": {
    "type": "object",
    "properties": {
      "user_id": {
        "type": "string",
        "description": "ID of the user performing the action (required for authorization)"
      },
      "org_id": {
        "type": "string",
        "description": "Organization ID"
      },
      "immediately": {
        "type": "boolean",
        "default": false,
        "description": "If true, cancel immediately instead of at period end"
      },
      "reason": {
        "type": "string",
        "description": "Cancellation reason for feedback"
      }
    },
    "required": ["user_id", "org_id"]
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "success": {
        "type": "boolean"
      },
      "subscription": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "status": { "type": "string" },
          "cancel_at_period_end": { "type": "boolean" },
          "canceled_at": { "type": "string", "format": "date-time" },
          "current_period_end": { "type": "string", "format": "date-time" }
        }
      },
      "message": { "type": "string" }
    }
  }
}
