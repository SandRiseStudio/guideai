{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "name": "billing.createPortalSession",
  "description": "Create a Stripe customer portal session for managing billing and payment methods.",
  "inputSchema": {
    "type": "object",
    "properties": {
      "user_id": {
        "type": "string",
        "description": "ID of the user performing the action (required for authorization)"
      },
      "org_id": {
        "type": "string",
        "description": "Organization ID"
      },
      "return_url": {
        "type": "string",
        "format": "uri",
        "description": "URL to return to after portal session"
      }
    },
    "required": ["user_id", "org_id", "return_url"]
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "success": {
        "type": "boolean"
      },
      "portal": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "url": { "type": "string", "format": "uri", "description": "Portal URL to redirect user to" },
          "expires_at": { "type": "string", "format": "date-time" }
        }
      }
    }
  }
}
