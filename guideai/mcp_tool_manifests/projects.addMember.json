{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "name": "projects.addMember",
  "description": "Add a member to a project with a specified role. User must already be an org member.",
  "inputSchema": {
    "type": "object",
    "properties": {
      "user_id": {
        "type": "string",
        "description": "ID of the user performing the action (required for authorization)"
      },
      "project_id": {
        "type": "string",
        "description": "Project ID"
      },
      "target_user_id": {
        "type": "string",
        "description": "ID of the user to add as a project member"
      },
      "role": {
        "type": "string",
        "enum": ["owner", "admin", "maintainer", "developer", "viewer"],
        "default": "developer",
        "description": "Role to assign to the new member"
      }
    },
    "required": ["user_id", "project_id", "target_user_id"]
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "success": {
        "type": "boolean"
      },
      "membership": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "project_id": { "type": "string" },
          "user_id": { "type": "string" },
          "role": { "type": "string" },
          "created_at": { "type": "string", "format": "date-time" }
        }
      },
      "message": { "type": "string" }
    }
  }
}
