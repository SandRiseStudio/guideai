{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "name": "orgs.projects",
  "description": "Manage projects within an organization. Projects group runs, behaviors, and agents for specific workstreams.",
  "inputSchema": {
    "type": "object",
    "properties": {
      "org_id": {
        "type": "string",
        "description": "Organization ID"
      },
      "action": {
        "type": "string",
        "enum": ["list", "get", "create", "update", "archive"],
        "default": "list",
        "description": "Action to perform"
      },
      "project_id": {
        "type": "string",
        "description": "Project ID (required for get/update/archive)"
      },
      "name": {
        "type": "string",
        "description": "Project name (for create/update)"
      },
      "description": {
        "type": "string",
        "description": "Project description"
      },
      "settings": {
        "type": "object",
        "description": "Project-specific settings"
      }
    },
    "required": ["org_id"]
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "success": {
        "type": "boolean"
      },
      "projects": {
        "type": "array",
        "description": "Project list (for list action)",
        "items": {
          "type": "object",
          "properties": {
            "id": {
              "type": "string"
            },
            "name": {
              "type": "string"
            },
            "description": {
              "type": "string"
            },
            "org_id": {
              "type": "string"
            },
            "created_at": {
              "type": "string",
              "format": "date-time"
            },
            "settings": {
              "type": "object"
            },
            "run_count": {
              "type": "integer"
            },
            "behavior_count": {
              "type": "integer"
            }
          }
        }
      },
      "project": {
        "type": "object",
        "description": "Project details (for get/create/update actions)"
      }
    }
  }
}
