{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "name": "orgs.updateMemberRole",
  "description": "Update a member's role in an organization. Requires admin or owner role.",
  "inputSchema": {
    "type": "object",
    "properties": {
      "user_id": {
        "type": "string",
        "description": "ID of the user performing the action (required for authorization)"
      },
      "org_id": {
        "type": "string",
        "description": "Organization ID"
      },
      "target_user_id": {
        "type": "string",
        "description": "ID of the user whose role to update"
      },
      "role": {
        "type": "string",
        "enum": ["owner", "admin", "member", "viewer"],
        "description": "New role to assign"
      }
    },
    "required": ["user_id", "org_id", "target_user_id", "role"]
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "success": {
        "type": "boolean"
      },
      "membership": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "org_id": { "type": "string" },
          "user_id": { "type": "string" },
          "role": { "type": "string" },
          "updated_at": { "type": "string", "format": "date-time" }
        }
      },
      "message": { "type": "string" }
    }
  }
}
