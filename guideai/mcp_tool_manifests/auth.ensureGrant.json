{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "name": "auth.ensureGrant",
  "description": "Perform a just-in-time authorization check for a tool invocation and return consent details or grant metadata.",
  "inputSchema": {
    "type": "object",
    "required": ["agent_id", "surface", "tool_name", "scopes"],
    "properties": {
      "agent_id": {"type": "string", "description": "Registered agent identifier."},
      "user_id": {"type": "string", "description": "Human user id when acting on behalf of a person."},
      "surface": {"type": "string", "enum": ["WEB", "CLI", "API", "VS_CODE", "MCP"]},
      "tool_name": {"type": "string", "description": "Tool/action identifier. Must match ACTION_REGISTRY_SPEC."},
      "scopes": {
        "type": "array",
        "items": {"type": "string"},
        "minItems": 1
      },
      "context": {
        "type": "object",
        "additionalProperties": {"type": "string"},
        "description": "Optional context such as run_id or resource identifiers."
      }
    },
    "additionalProperties": false
  },
  "outputSchema": {
    "type": "object",
    "required": ["decision"],
    "properties": {
      "decision": {"type": "string", "enum": ["ALLOW", "CONSENT_REQUIRED", "DENY"]},
      "reason": {"type": "string"},
      "consent_url": {"type": "string", "format": "uri"},
      "consent_request_id": {"type": "string"},
      "grant": {
        "type": "object",
        "properties": {
          "grant_id": {"type": "string"},
          "expires_at": {"type": "string", "format": "date-time"},
          "provider": {"type": "string"},
          "scopes": {
            "type": "array",
            "items": {"type": "string"}
          }
        },
        "additionalProperties": true
      },
      "audit_action_id": {"type": "string"}
    },
    "additionalProperties": false
  },
  "errors": [
    {
      "code": "auth-policy-denied",
      "description": "Policy evaluation returned DENY; downstream tool must abort execution.",
      "httpStatus": 403
    },
    {
      "code": "auth-consent-timeout",
      "description": "Consent was not granted before timeout window expired.",
      "httpStatus": 408
    }
  ]
}
