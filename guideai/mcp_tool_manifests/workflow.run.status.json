{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "name": "workflow.run.status",
  "description": "Check the status of a workflow run, including step progress, token usage, and behavior citations.",
  "inputSchema": {
    "type": "object",
    "required": ["run_id"],
    "properties": {
      "run_id": {
        "type": "string",
        "description": "Run identifier (e.g., run-<12-char-hex>)"
      }
    },
    "additionalProperties": false
  },
  "outputSchema": {
    "type": "object",
    "required": ["run_id", "status"],
    "properties": {
      "run_id": {"type": "string"},
      "template_id": {"type": "string"},
      "template_name": {"type": "string"},
      "role_focus": {"type": "string"},
      "status": {
        "type": "string",
        "enum": ["PENDING", "RUNNING", "COMPLETED", "FAILED", "CANCELLED"]
      },
      "actor": {
        "type": "object",
        "properties": {
          "id": {"type": "string"},
          "role": {"type": "string"},
          "surface": {"type": "string"}
        }
      },
      "steps": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "step_id": {"type": "string"},
            "status": {"type": "string"},
            "prompt_rendered": {"type": "string"},
            "behaviors_used": {"type": "array", "items": {"type": "string"}},
            "output": {"type": ["string", "null"]},
            "token_count": {"type": ["integer", "null"]},
            "started_at": {"type": ["string", "null"]},
            "completed_at": {"type": ["string", "null"]},
            "error": {"type": ["string", "null"]}
          }
        }
      },
      "started_at": {"type": "string", "format": "date-time"},
      "completed_at": {"type": ["string", "null"], "format": "date-time"},
      "total_tokens": {"type": "integer"},
      "behaviors_cited": {"type": "array", "items": {"type": "string"}},
      "metadata": {"type": "object"}
    }
  }
}
