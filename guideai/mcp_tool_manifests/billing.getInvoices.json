{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "name": "billing.getInvoices",
  "description": "Get invoice history for an organization.",
  "inputSchema": {
    "type": "object",
    "properties": {
      "user_id": {
        "type": "string",
        "description": "ID of the user performing the action (required for authorization)"
      },
      "org_id": {
        "type": "string",
        "description": "Organization ID to get invoices for"
      },
      "status": {
        "type": "string",
        "enum": ["draft", "open", "paid", "void", "uncollectible"],
        "description": "Filter by invoice status"
      },
      "limit": {
        "type": "integer",
        "minimum": 1,
        "maximum": 100,
        "default": 10,
        "description": "Maximum number of invoices to return"
      },
      "starting_after": {
        "type": "string",
        "description": "Cursor for pagination (invoice ID)"
      }
    },
    "required": ["user_id", "org_id"]
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "success": {
        "type": "boolean"
      },
      "invoices": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "id": { "type": "string" },
            "number": { "type": "string" },
            "status": { "type": "string" },
            "amount_due": { "type": "integer", "description": "Amount in cents" },
            "amount_paid": { "type": "integer" },
            "currency": { "type": "string" },
            "period_start": { "type": "string", "format": "date-time" },
            "period_end": { "type": "string", "format": "date-time" },
            "created_at": { "type": "string", "format": "date-time" },
            "paid_at": { "type": "string", "format": "date-time" },
            "hosted_invoice_url": { "type": "string" },
            "pdf_url": { "type": "string" }
          }
        }
      },
      "has_more": { "type": "boolean" }
    }
  }
}
