{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "name": "fine-tuning.list",
  "description": "List fine-tuning jobs with status and progress information.",
  "inputSchema": {
    "type": "object",
    "properties": {
      "status": {
        "type": "string",
        "enum": ["PENDING", "RUNNING", "COMPLETED", "FAILED", "CANCELLED"]
      },
      "model_name": {
        "type": "string",
        "description": "Filter by base model name"
      },
      "limit": {
        "type": "integer",
        "default": 20,
        "description": "Maximum number of results to return"
      }
    },
    "required": []
  },
  "outputSchema": {
    "type": "array",
    "items": {
      "type": "object",
      "properties": {
        "job_id": {
          "type": "string"
        },
        "model_name": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "created_at": {
          "type": "string"
        },
        "progress": {
          "type": "object"
        },
        "model_registry": {
          "type": "object"
        }
      }
    }
  }
}
