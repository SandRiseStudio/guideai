{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "name": "agentRegistry.bootstrap",
  "description": "Bootstrap builtin agents from AGENT_*.md playbook files. Admin only. Parses playbooks, creates or updates agents, and publishes them.",
  "inputSchema": {
    "type": "object",
    "properties": {
      "actors_dir": {
        "type": "string",
        "description": "Optional: custom directory containing AGENT_*.md files"
      },
      "force_update": {
        "type": "boolean",
        "default": false,
        "description": "Force update existing agents even if unchanged"
      },
      "actor_id": {
        "type": "string",
        "description": "User ID performing the bootstrap (must be admin)"
      }
    },
    "required": ["actor_id"]
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "success": {
        "type": "boolean",
        "description": "Whether the bootstrap completed successfully"
      },
      "created": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "agent_id": {
              "type": "string"
            },
            "name": {
              "type": "string"
            },
            "source": {
              "type": "string",
              "description": "Source playbook file"
            }
          }
        },
        "description": "Agents that were newly created"
      },
      "updated": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "agent_id": {
              "type": "string"
            },
            "name": {
              "type": "string"
            },
            "source": {
              "type": "string"
            },
            "new_version": {
              "type": "integer"
            }
          }
        },
        "description": "Agents that were updated with new versions"
      },
      "skipped": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "source": {
              "type": "string"
            },
            "reason": {
              "type": "string"
            }
          }
        },
        "description": "Agents that were skipped"
      },
      "errors": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "source": {
              "type": "string"
            },
            "error": {
              "type": "string"
            }
          }
        },
        "description": "Errors encountered during bootstrap"
      },
      "summary": {
        "type": "object",
        "properties": {
          "total_playbooks": {
            "type": "integer"
          },
          "created_count": {
            "type": "integer"
          },
          "updated_count": {
            "type": "integer"
          },
          "skipped_count": {
            "type": "integer"
          },
          "error_count": {
            "type": "integer"
          }
        }
      }
    },
    "required": ["success", "created", "updated", "skipped", "errors", "summary"]
  }
}
