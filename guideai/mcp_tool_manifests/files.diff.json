{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "name": "files.diff",
  "description": "Preview a unified diff of proposed changes before writing. Compares current file content with proposed new content. Useful for review and validation before committing changes.",
  "inputSchema": {
    "type": "object",
    "properties": {
      "path": {
        "type": "string",
        "description": "Path to the file (existing or new) (required)"
      },
      "new_content": {
        "type": "string",
        "description": "Proposed new content for the file (required)"
      },
      "context_lines": {
        "type": "integer",
        "minimum": 0,
        "maximum": 20,
        "default": 3,
        "description": "Number of context lines around changes (default: 3)"
      },
      "encoding": {
        "type": "string",
        "default": "utf-8",
        "description": "File encoding (default: utf-8)"
      }
    },
    "required": ["path", "new_content"]
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "success": {
        "type": "boolean",
        "description": "Whether the operation succeeded"
      },
      "diff": {
        "type": "string",
        "description": "Unified diff output"
      },
      "has_changes": {
        "type": "boolean",
        "description": "Whether there are any differences"
      },
      "is_new_file": {
        "type": "boolean",
        "description": "Whether the file does not currently exist"
      },
      "stats": {
        "type": "object",
        "properties": {
          "lines_added": { "type": "integer" },
          "lines_removed": { "type": "integer" },
          "lines_changed": { "type": "integer" }
        },
        "description": "Summary statistics of changes"
      },
      "path": {
        "type": "string",
        "description": "Normalized absolute path"
      },
      "error": {
        "type": "string",
        "description": "Error message if success is false"
      }
    },
    "required": ["success"]
  }
}
