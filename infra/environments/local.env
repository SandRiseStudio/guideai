# GuideAI Local Development Environment Configuration
# Last Updated: 2025-11-11
# Purpose: Local development with minimal dependencies (SQLite/JSON where possible)

# ============================================================================
# Environment Metadata
# ============================================================================
ENVIRONMENT=local
DEPLOY_VERSION=dev

# ============================================================================
# Multi-Environment Settings (New Config Abstraction)
# ============================================================================

# Storage Provider (local filesystem, no cloud required)
STORAGE__PROVIDER=local
STORAGE__LOCAL_PATH=./data

# Database Provider (local PostgreSQL via docker-compose)
DATABASE__PROVIDER=local
DATABASE__POSTGRES_URL=postgresql://guideai_user:local_dev_pw@localhost:5432/guideai
DATABASE__POOL_SIZE=5
DATABASE__MAX_OVERFLOW=10

# Cache Provider (local Redis via docker-compose)
CACHE__PROVIDER=local
CACHE__REDIS_URL=redis://localhost:6379/0

# Secrets Provider (environment variables only)
SECRETS__PROVIDER=env
SECRETS__SECRET_PATH_PREFIX=guideai

# Observability Provider (local Prometheus + Grafana)
OBSERVABILITY__PROVIDER=local
OBSERVABILITY__PROMETHEUS_ENABLED=true
OBSERVABILITY__GRAFANA_ENABLED=true

# ============================================================================
# Legacy Database DSN Strings (for backward compatibility)
# ============================================================================
GUIDEAI_BEHAVIOR_PG_DSN=postgresql://guideai_behavior:dev_behavior_pass@localhost:5433/behaviors
GUIDEAI_WORKFLOW_PG_DSN=postgresql://guideai_workflow:dev_workflow_pass@localhost:5434/workflows
GUIDEAI_ACTION_PG_DSN=postgresql://guideai_user:local_dev_pw@localhost:5435/guideai_action
GUIDEAI_RUN_PG_DSN=postgresql://guideai_user:local_dev_pw@localhost:5436/guideai_run
GUIDEAI_COMPLIANCE_PG_DSN=postgresql://guideai_user:local_dev_pw@localhost:5437/guideai_compliance
GUIDEAI_METRICS_PG_DSN=postgresql://guideai_user:local_dev_pw@localhost:5438/guideai_metrics
GUIDEAI_TELEMETRY_PG_DSN=postgresql://guideai_telemetry:dev_telemetry_pass@localhost:5439/telemetry

# ============================================================================
# API Service Configuration
# ============================================================================
API_HOST=0.0.0.0
API_PORT=8000  # Internal port, gateway proxies 8080 -> 8000
API_WORKERS=1
API_LOG_LEVEL=debug
API_RELOAD=true
# Gateway URL - clients should connect via gateway for auth/rate-limiting
GUIDEAI_GATEWAY_URL=http://localhost:8080

# CORS Settings (local - very permissive for development)
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:5173,http://127.0.0.1:3000
CORS_ALLOW_CREDENTIALS=true

# ============================================================================
# MCP Server Configuration
# ============================================================================
MCP_HOST=0.0.0.0
MCP_PORT=3000
MCP_LOG_LEVEL=debug
MCP_TRANSPORT=stdio

# ============================================================================
# Authentication & Security (Development - Less Strict)
# ============================================================================
# JWT_SECRET_KEY — set in your .env override (run: openssl rand -hex 32)
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480  # 8 hours for dev convenience
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# Device Flow OAuth (Local - GitHub OAuth App or Mock)
OAUTH_CLIENT_ID=local_github_client_id
OAUTH_CLIENT_SECRET=local_github_client_secret
OAUTH_DEVICE_CODE_URL=https://github.com/login/device/code
OAUTH_TOKEN_URL=https://github.com/login/oauth/access_token
OAUTH_USER_URL=https://api.github.com/user

# Session Management
SESSION_SECRET=local_dev_session_secret
SESSION_COOKIE_SECURE=false  # Allow HTTP in local dev
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=lax

# ============================================================================
# Embedding Configuration
# ============================================================================
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_ROLLOUT_PERCENTAGE=100

# ============================================================================
# Feature Flags (Local - Enable All Features)
# ============================================================================
FEATURE_MULTI_TENANT=false
FEATURE_FINE_TUNING=true
FEATURE_ADVANCED_RETRIEVAL=true
FEATURE_COLLABORATION=true
FEATURE_TRACE_ANALYSIS=true

# ============================================================================
# Telemetry & Analytics
# ============================================================================
TELEMETRY_ENABLED=true
TELEMETRY_EXPORT_PATH=./data/telemetry
ANALYTICS_WAREHOUSE_PATH=./data/analytics.duckdb

# ============================================================================
# Rate Limiting (Local - Very Permissive)
# ============================================================================
RATE_LIMIT_DEVICE_FLOW=1000/min
RATE_LIMIT_API=10000/min
RATE_LIMIT_MCP=10000/min

# ============================================================================
# Logging Configuration
# ============================================================================
LOG_LEVEL=debug
LOG_FORMAT=json
LOG_FILE=./logs/guideai.log

ANTHROPIC_API_KEY=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
ANTHROPIC_MODEL=claude-opus-4-20250514
