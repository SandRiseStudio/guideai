# GuideAI Staging Environment Configuration
# Last Updated: 2025-12-19
# Purpose: Minimal staging environment for compliance validation

# ============================================================================
# Environment Metadata
# ============================================================================
ENVIRONMENT=staging
DEPLOY_TIMESTAMP=2025-12-19T00:00:00Z
DEPLOY_VERSION=1.0.0-staging

# ============================================================================
# Database Configuration
# ============================================================================
# PostgreSQL - Main Services
POSTGRES_HOST=postgres-staging
POSTGRES_PORT=5432
POSTGRES_USER=guideai_staging
POSTGRES_PASSWORD=staging_secure_password_change_me
POSTGRES_DB=guideai_staging

# Individual Service Databases
BEHAVIOR_DB=guideai_behaviors_staging
ACTION_DB=guideai_actions_staging
RUN_DB=guideai_runs_staging
COMPLIANCE_DB=guideai_compliance_staging
METRICS_DB=guideai_metrics_staging
TELEMETRY_DB=guideai_telemetry_staging

# Connection Pool Settings (reduced for staging)
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# PostgreSQL DSN Connection Strings (for services that require them)
# Format: postgresql://user:password@host:port/database
GUIDEAI_BEHAVIOR_PG_DSN=postgresql://guideai_behavior:behavior_test_pass@host.containers.internal:6433/guideai_behavior
GUIDEAI_WORKFLOW_PG_DSN=postgresql://guideai_workflow:workflow_test_pass@host.containers.internal:6434/guideai_workflow
GUIDEAI_ACTION_PG_DSN=postgresql://guideai_action:action_test_pass@host.containers.internal:6435/guideai_action
GUIDEAI_RUN_PG_DSN=postgresql://guideai_run:run_test_pass@host.containers.internal:6436/guideai_run
GUIDEAI_COMPLIANCE_PG_DSN=postgresql://guideai_compliance:compliance_test_pass@host.containers.internal:6437/guideai_compliance
GUIDEAI_METRICS_PG_DSN=postgresql://guideai_metrics_user:local_metrics_dev_pw@host.containers.internal:6439/guideai_metrics
GUIDEAI_TELEMETRY_PG_DSN=postgresql://guideai_telemetry:telemetry_test_pass@host.containers.internal:6432/guideai_telemetry
GUIDEAI_TRACE_ANALYSIS_PG_DSN=postgresql://guideai_action:action_test_pass@host.containers.internal:6435/guideai_action

# Host overrides for Podman/Docker containers hitting host databases
GUIDEAI_PG_HOST_BEHAVIOR=host.containers.internal
GUIDEAI_PG_PORT_BEHAVIOR=6433
GUIDEAI_PG_HOST_WORKFLOW=host.containers.internal
GUIDEAI_PG_PORT_WORKFLOW=6434
GUIDEAI_PG_HOST_ACTION=host.containers.internal
GUIDEAI_PG_PORT_ACTION=6435
GUIDEAI_PG_HOST_RUN=host.containers.internal
GUIDEAI_PG_PORT_RUN=6436
GUIDEAI_PG_HOST_COMPLIANCE=host.containers.internal
GUIDEAI_PG_PORT_COMPLIANCE=6437
GUIDEAI_PG_HOST_METRICS=host.containers.internal
GUIDEAI_PG_PORT_METRICS=6439
GUIDEAI_PG_HOST_TELEMETRY=host.containers.internal
GUIDEAI_PG_PORT_TELEMETRY=6432
GUIDEAI_PG_HOST_TRACE_ANALYSIS=host.containers.internal
GUIDEAI_PG_PORT_TRACE_ANALYSIS=6435

# ============================================================================
# Redis Configuration
# ============================================================================
REDIS_HOST=redis-staging
REDIS_PORT=6379
REDIS_PASSWORD=staging_redis_password_change_me
REDIS_DB=0

# ============================================================================
# API Service Configuration
# ============================================================================
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=2
API_LOG_LEVEL=info
API_RELOAD=false
API_BASE_URL=http://localhost:8000

# CORS Settings (staging - more permissive)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000,http://localhost:5173
CORS_ALLOW_CREDENTIALS=true

# ============================================================================
# MCP Server Configuration
# ============================================================================
MCP_HOST=0.0.0.0
MCP_PORT=3000
MCP_LOG_LEVEL=info
MCP_TRANSPORT=stdio

# ============================================================================
# Authentication & Security
# ============================================================================
# JWT Configuration
JWT_SECRET_KEY=staging_jwt_secret_change_me_in_production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Device Flow OAuth (Staging - GitHub OAuth App)
OAUTH_CLIENT_ID=staging_github_client_id
OAUTH_CLIENT_SECRET=staging_github_client_secret
OAUTH_DEVICE_CODE_URL=https://github.com/login/device/code
OAUTH_TOKEN_URL=https://github.com/login/oauth/access_token
OAUTH_USER_URL=https://api.github.com/user

# Session Management
SESSION_SECRET=staging_session_secret_change_me
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=lax

# ============================================================================
# Compliance Service Configuration
# ============================================================================
COMPLIANCE_HOST=0.0.0.0
COMPLIANCE_PORT=8001
COMPLIANCE_DB_HOST=postgres-staging
COMPLIANCE_DB_PORT=6437
COMPLIANCE_COVERAGE_TARGET=0.95
COMPLIANCE_CHECK_INTERVAL=300

# ============================================================================
# Metrics & Telemetry
# ============================================================================
METRICS_ENABLED=true
METRICS_PORT=9090
METRICS_INTERVAL=60

TELEMETRY_ENABLED=true
TELEMETRY_BATCH_SIZE=100
TELEMETRY_FLUSH_INTERVAL=30

# OpenTelemetry Configuration
OTEL_SERVICE_NAME=guideai-staging
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_TRACES_SAMPLER=always_on
OTEL_METRICS_EXPORTER=none
OTEL_LOGS_EXPORTER=none

# ============================================================================
# Analytics Dashboard (Metabase)
# ============================================================================
METABASE_ENABLED=false
METABASE_PORT=3001
METABASE_DB_FILE=/metabase-data/metabase.db

# ============================================================================
# Feature Flags
# ============================================================================
FEATURE_BEHAVIOR_REUSE=true
FEATURE_COMPLIANCE_TRACKING=true
FEATURE_METRICS_COLLECTION=true
FEATURE_DEVICE_FLOW_AUTH=true
FEATURE_MCP_TOOLS=true

# ============================================================================
# Logging Configuration
# ============================================================================
LOG_LEVEL=info
LOG_FORMAT=json
LOG_OUTPUT=stdout
LOG_FILE_ENABLED=false

# ============================================================================
# Performance Tuning (Staging - Conservative)
# ============================================================================
MAX_CONCURRENT_REQUESTS=50
REQUEST_TIMEOUT=30
KEEPALIVE_TIMEOUT=5
GRACEFUL_SHUTDOWN_TIMEOUT=10

# Retrieval Engine
RETRIEVAL_MAX_RESULTS=10
RETRIEVAL_TIMEOUT=5
EMBEDDING_CACHE_SIZE=1000

# Embedding Model Configuration (Phase 1 Optimization: behavior_curate_behavior_handbook)
# all-MiniLM-L6-v2: 80MB disk, ~300-500MB memory vs BGE-M3: 2.3GB disk, 3-4GB memory
# Quality retention: ~85% of BGE-M3 (acceptable for behavior retrieval use case)
# Lazy loading: Model loads on first retrieve() call instead of container startup
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_MODEL_LAZY_LOAD=true

# Phase 2 Task 8: Gradual Rollout Configuration (behavior_instrument_metrics_pipeline)
# Rollout percentage for all-MiniLM-L6-v2 (0-100):
#   0% = all requests use BGE-M3 (baseline)
#   100% = full rollout to new model (current - rollout complete 2025-11-24)
# Deterministic hash-based cohort routing ensures same user_id always gets same model
# ROLLBACK: Set to 0 to route all traffic back to BGE-M3 (see docs/EMBEDDING_ROLLBACK_RUNBOOK.md)
EMBEDDING_ROLLOUT_PERCENTAGE=100

# ============================================================================
# Health Check Configuration
# ============================================================================
HEALTH_CHECK_INTERVAL=30
HEALTH_CHECK_TIMEOUT=5
HEALTH_CHECK_RETRIES=3

# ============================================================================
# Backup & Recovery (Disabled in Staging)
# ============================================================================
BACKUP_ENABLED=false
BACKUP_SCHEDULE="0 2 * * *"
BACKUP_RETENTION_DAYS=7

# ============================================================================
# Network Configuration
# ============================================================================
NETWORK_NAME=guideai-staging-network
NETWORK_DRIVER=bridge

# ============================================================================
# Volume Configuration
# ============================================================================
DATA_DIR=/var/lib/guideai/staging
BACKUP_DIR=/var/backups/guideai/staging
LOG_DIR=/var/log/guideai/staging

# ============================================================================
# Monitoring & Alerting (Minimal in Staging)
# ============================================================================
MONITORING_ENABLED=false
ALERTING_ENABLED=false

# ============================================================================
# PRD KPI Targets
# ============================================================================
KPI_BEHAVIOR_REUSE_TARGET=0.70
KPI_TOKEN_SAVINGS_TARGET=0.30
KPI_COMPLETION_RATE_TARGET=0.80
KPI_COMPLIANCE_COVERAGE_TARGET=0.95

# ============================================================================
# Service-Specific Ports
# ============================================================================
# PostgreSQL Services
POSTGRES_BEHAVIORS_PORT=5433
POSTGRES_ACTIONS_PORT=5434
POSTGRES_RUNS_PORT=5435
POSTGRES_COMPLIANCE_PORT=6437
POSTGRES_METRICS_PORT=5438
POSTGRES_TELEMETRY_PORT=5439

# ============================================================================
# Development & Debug (Staging Only)
# ============================================================================
DEBUG=false
RELOAD_ON_CHANGE=false
PROFILE_ENABLED=false
