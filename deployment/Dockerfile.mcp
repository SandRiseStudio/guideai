# GuideAI MCP Server
# Container for Model Context Protocol server with stdio transport
# Last Updated: 2025-11-25 (Epic 6 - MCP Server Deployment)

# ============================================================================
# Stage 1: Builder - Install dependencies
# ============================================================================
FROM python:3.11-slim AS builder

WORKDIR /build

# Install build dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    g++ \
    make \
    libpq-dev \
    && rm -rf /var/lib/apt/lists/*

# Copy dependency files
COPY pyproject.toml ./
COPY docs/README.md ./docs/README.md
COPY guideai/__init__.py guideai/__init__.py
COPY packages/ ./packages/

# Install Python dependencies.
# Note: This repo is a monorepo; the MCP server and guideai core code import
# local packages like `raze` and `amprealize`, so we install them from ./packages/.
RUN pip install --no-cache-dir --upgrade pip setuptools wheel && \
    pip install --no-cache-dir -e ./packages/raze && \
    pip install --no-cache-dir -e ./packages/amprealize && \
    pip install --no-cache-dir -e .[telemetry,postgres,redis] && \
    pip install --no-cache-dir psutil

# ============================================================================
# Stage 2: Runtime - Minimal production image
# ============================================================================
FROM python:3.11-slim

WORKDIR /app

# Install runtime dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    libpq5 \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Create non-root user
RUN useradd -m -u 1000 -s /bin/bash guideai && \
    chown -R guideai:guideai /app

# Copy Python packages from builder
COPY --from=builder /usr/local/lib/python3.11/site-packages /usr/local/lib/python3.11/site-packages
COPY --from=builder /usr/local/bin /usr/local/bin

# Copy application code
COPY --chown=guideai:guideai guideai/ ./guideai/
COPY --chown=guideai:guideai mcp/ ./mcp/
COPY --chown=guideai:guideai schema/ ./schema/
COPY --chown=guideai:guideai scripts/mcp_health_check.py ./scripts/mcp_health_check.py
COPY --chown=guideai:guideai pyproject.toml ./

# Create necessary directories
RUN mkdir -p data/behaviors data/workflows data/actions data/runs data/compliance && \
    chown -R guideai:guideai data/

# Switch to non-root user
USER guideai

# Environment configuration
ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PATH="/home/guideai/.local/bin:$PATH" \
    ENVIRONMENT=staging \
    MCP_TRANSPORT=stdio \
    MCP_IDLE_TIMEOUT=3600 \
    MCP_SHUTDOWN_TIMEOUT=30

# Health check via JSON-RPC health method (Epic 6 - Health Check Endpoints)
# The health check sends a JSON-RPC request and parses the response status
HEALTHCHECK --interval=30s --timeout=10s --start-period=40s --retries=3 \
    CMD echo '{"jsonrpc":"2.0","id":"health","method":"health"}' | \
        timeout 5 python -m guideai.mcp_server 2>/dev/null | \
        head -1 | python -c "import sys,json; d=json.load(sys.stdin); exit(0 if d.get('result',{}).get('status') in ('healthy','degraded') else 1)" || exit 1

# Expose MCP port (for future HTTP transport)
EXPOSE 3000

# Run MCP server
CMD ["python", "-m", "guideai.mcp_server"]
