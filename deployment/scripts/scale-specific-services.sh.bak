#!/bin/bash

# GuideAI Service Scaling Script
# Scales specific services based on load requirements
# Date: 2025-11-08
# Usage: ./deployment/scripts/scale-specific-services.sh [scale|config|status|help]

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_DIR="$(dirname "$SCRIPT_DIR")"
COMPOSE_FILE="$PROJECT_DIR/podman-compose-scaled.yml"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

log_info() { echo -e "${BLUE}[INFO]${NC} $1"; }
log_success() { echo -e "${GREEN}[SUCCESS]${NC} $1"; }
log_warning() { echo -e "${YELLOW}[WARNING]${NC} $1"; }
log_error() { echo -e "${RED}[ERROR]${NC} $1"; }

# Scale configurations for different environments
declare -A SCALE_CONFIGS=(
    ["development"]="behavior-service:2,action-service:1,run-service:2,compliance-service:1,agent-orchestrator:1"
    ["staging"]="behavior-service:3,action-service:2,run-service:3,compliance-service:1,agent-orchestrator:2"
    ["production"]="behavior-service:5,action-service:3,run-service:4,compliance-service:1,agent-orchestrator:3"
    ["high-load"]="behavior-service:8,action-service:5,run-service:6,compliance-service:2,agent-orchestrator:4"
    ["stress-test"]="behavior-service:10,action-service:6,run-service:8,compliance-service:2,agent-orchestrator:5"
)

# Get current scaling configuration
get_current_scale() {
    cd "$PROJECT_DIR"
    podman-compose -f "$COMPOSE_FILE" ps --services --scale
}

# Scale service to specific replica count
scale_service() {
    local service=$1
    local replicas=$2

    # Validate service name
    local valid_services=("behavior-service" "action-service" "run-service" "compliance-service" "agent-orchestrator")
    local is_valid=false
    for valid_service in "${valid_services[@]}"; do
        if [[ "$service" == "$valid_service" ]]; then
            is_valid=true
            break
        fi
    done

    if [[ "$is_valid" == "false" ]]; then
        log_error "Invalid service name: $service"
        log_info "Valid services: ${valid_services[*]}"
        exit 1
    fi

    # Validate replicas
    if ! [[ "$replicas" =~ ^[0-9]+$ ]] || [[ "$replicas" -lt 1 ]] || [[ "$replicas" -gt 20 ]]; then
        log_error "Invalid replica count: $replicas (must be 1-20)"
        exit 1
    fi

    log_info "Scaling $service to $replicas replicas..."

    cd "$PROJECT_DIR"

    # Scale the service
    if podman-compose -f "$COMPOSE_FILE" up -d --scale "$service=$replicas"; then
        log_success "$service scaled to $replicas replicas"
    else
        log_error "Failed to scale $service"
        return 1
    fi

    # Wait for scaling to complete
    log_info "Waiting for scaling to complete..."
    sleep 15

    # Verify scaling
    local running_containers=$(podman-compose -f "$COMPOSE_FILE" ps "$service" | grep -c "Up" || echo "0")

    if [[ "$running_containers" -ge "$replicas" ]]; then
        log_success "Scaling verified: $running_containers/$replicas containers running"
    else
        log_warning "Scaling incomplete: $running_containers/$replicas containers running"
    fi

    # Check service health after scaling
    check_scaled_service_health "$service"
}

# Check health of scaled service
check_scaled_service_health() {
    local service=$1
    local port

    case $service in
        "behavior-service") port=8001 ;;
        "action-service") port=8002 ;;
        "run-service") port=8003 ;;
        "compliance-service") port=8004 ;;
        "agent-orchestrator") port=8005 ;;
    esac

    log_info "Checking health of scaled $service..."

    local max_attempts=20
    local attempt=1
    local healthy_instances=0
    local total_instances=$replicas

    while [[ $attempt -le $max_attempts ]]; do
        for i in $(seq 1 $replicas); do
            if curl -s -f http://localhost:$port/health > /dev/null 2>&1; then
                ((healthy_instances++))
            fi
        done

        log_info "Healthy instances: $healthy_instances/$total_instances"

        if [[ $healthy_instances -eq $total_instances ]]; then
            log_success "All instances of $service are healthy"
            break
        fi

        if [[ $attempt -eq $max_attempts ]]; then
            log_error "Not all instances of $service are healthy after $max_attempts attempts"
            return 1
        fi

        sleep 5
        ((attempt++))
    done
}

# Scale to predefined configuration
scale_to_config() {
    local config=$1

    if [[ ! -v "SCALE_CONFIGS[$config]" ]]; then
        log_error "Unknown configuration: $config"
        log_info "Available configurations: ${!SCALE_CONFIGS[*]}"
        exit 1
    fi

    log_info "Scaling to $config configuration..."

    local services="${SCALE_CONFIGS[$config]}"
    IFS=',' read -ra SERVICE_CONFIGS <<< "$services"

    local failed_services=()

    for service_config in "${SERVICE_CONFIGS[@]}"; do
        IFS=':' read -ra SERVICE_REPLICA <<< "$service_config"
        local service_name="${SERVICE_REPLICA[0]}"
        local replica_count="${SERVICE_REPLICA[1]}"

        log_info "Scaling $service_name to $replica_count replicas..."

        if ! scale_service "$service_name" "$replica_count"; then
            failed_services+=("$service_name")
        fi
    done

    if [[ ${#failed_services[@]} -eq 0 ]]; then
        log_success "Successfully scaled to $config configuration"
    else
        log_error "Failed to scale services: ${failed_services[*]}"
        return 1
    fi
}

# Show current status
show_status() {
    log_info "Current scaling status:"

    cd "$PROJECT_DIR"
    echo ""
    echo "=== CONTAINER STATUS ==="
    podman-compose -f "$COMPOSE_FILE" ps

    echo ""
    echo "=== REPLICA COUNTS ==="
    for service in behavior-service action-service run-service compliance-service agent-orchestrator; do
        local count=$(podman-compose -f "$COMPOSE_FILE" ps --services --filter "name=$service" | wc -l)
        if [[ $count -gt 0 ]]; then
            echo "$service: $count replicas"
        else
            echo "$service: 0 replicas (not running)"
        fi
    done

    echo ""
    echo "=== SERVICE HEALTH ==="
    for port in 8001 8002 8003 8004 8005; do
        if curl -s -f http://localhost:$port/health > /dev/null 2>&1; then
            echo "Port $port: ✅ Healthy"
        else
            echo "Port $port: ❌ Unhealthy"
        fi
    done
}

# Show performance metrics
show_performance() {
    log_info "Performance metrics for scaled services..."

    cd "$PROJECT_DIR"

    echo ""
    echo "=== CPU USAGE ==="
    podman stats --no-stream --format "table {{.Container}}\t{{.CPUPerc}}\t{{.MemUsage}}" \
        | grep -E "(behavior|action|run|compliance|orchestrator)" || true

    echo ""
    echo "=== MEMORY USAGE ==="
    podman stats --no-stream --format "table {{.Container}}\t{{.MemUsage}}" \
        | grep -E "(behavior|action|run|compliance|orchestrator)" || true

    echo ""
    echo "=== NETWORK TRAFFIC ==="
    podman stats --no-stream --format "table {{.Container}}\t{{.NetIO}}" \
        | grep -E "(behavior|action|run|compliance|orchestrator)" || true
}

# Auto-scale based on load
auto_scale() {
    local service=$1
    local threshold_cpu=${2:-80}
    local threshold_memory=${3:-85}
    local min_replicas=${4:-1}
    local max_replicas=${5:-10}

    log_info "Auto-scaling $service (CPU: ${threshold_cpu}%, Memory: ${threshold_memory}%)"

    # Get current replicas
    local current_replicas=$(podman-compose -f "$COMPOSE_FILE" ps --services --filter "name=$service" | wc -l)
    log_info "Current replicas: $current_replicas"

    # Check CPU and memory usage
    local cpu_usage=$(podman stats --no-stream --format "{{.CPUPerc}}" \
        | grep -E "$service" | head -1 | sed 's/%//')

    local memory_usage=$(podman stats --no-stream --format "{{.MemPerc}}" \
        | grep -E "$service" | head -1 | sed 's/%//')

    if [[ -z "$cpu_usage" ]]; then
        log_warning "Could not determine CPU usage for $service"
        return 1
    fi

    log_info "Current CPU: ${cpu_usage}%, Memory: ${memory_usage}%"

    # Determine scaling action
    local new_replicas=$current_replicas

    if (( $(echo "$cpu_usage > $threshold_cpu" | bc -l) )) || \
       (( $(echo "$memory_usage > $threshold_memory" | bc -l) )); then
        # Scale up
        if [[ $current_replicas -lt $max_replicas ]]; then
            new_replicas=$((current_replicas + 1))
            log_info "High usage detected, scaling up to $new_replicas replicas"
        else
            log_info "Already at maximum replicas ($max_replicas)"
        fi
    elif (( $(echo "$cpu_usage < 30" | bc -l) )) && \
         (( $(echo "$memory_usage < 50" | bc -l) )); then
        # Scale down
        if [[ $current_replicas -gt $min_replicas ]]; then
            new_replicas=$((current_replicas - 1))
            log_info "Low usage detected, scaling down to $new_replicas replicas"
        else
            log_info "Already at minimum replicas ($min_replicas)"
        fi
    else
        log_info "Usage within normal range, no scaling needed"
        return 0
    fi

    if [[ $new_replicas -ne $current_replicas ]]; then
        scale_service "$service" "$new_replicas"
    fi
}

# Main function
main() {
    local command=${1:-status}

    case $command in
        "scale")
            if [[ $# -lt 3 ]]; then
                log_error "Usage: $0 scale <service> <replicas>"
                exit 1
            fi
            scale_service "$2" "$3"
            ;;
        "config")
            if [[ $# -lt 2 ]]; then
                log_error "Usage: $0 config <configuration_name>"
                exit 1
            fi
            scale_to_config "$2"
            ;;
        "status")
            show_status
            ;;
        "performance")
            show_performance
            ;;
        "auto")
            if [[ $# -lt 2 ]]; then
                log_error "Usage: $0 auto <service> [cpu_threshold] [memory_threshold] [min_replicas] [max_replicas]"
                exit 1
            fi
            auto_scale "$2" "${3:-80}" "${4:-85}" "${5:-1}" "${6:-10}"
            ;;
        "configs"|"list")
            log_info "Available scaling configurations:"
            for config in "${!SCALE_CONFIGS[@]}"; do
                echo "  $config: ${SCALE_CONFIGS[$config]}"
            done
            ;;
        "help"|"-h"|"--help")
            echo "Usage: $0 [command] [args]"
            echo ""
            echo "Commands:"
            echo "  scale <service> <replicas>     - Scale specific service to replica count"
            echo "  config <name>                  - Scale to predefined configuration"
            echo "  status                         - Show current scaling status"
            echo "  performance                    - Show performance metrics"
            echo "  auto <service> [params]        - Auto-scale based on load"
            echo "  configs                        - List available configurations"
            echo "  help                           - Show this help"
            echo ""
            echo "Valid services:"
            echo "  behavior-service, action-service, run-service"
            echo "  compliance-service, agent-orchestrator"
            echo ""
            echo "Examples:"
            echo "  $0 scale behavior-service 5"
            echo "  $0 config production"
            echo "  $0 auto behavior-service 70 80 2 8"
            ;;
        *)
            log_error "Unknown command: $command"
            echo "Use '$0 help' for usage information"
            exit 1
            ;;
    esac
}

# Run main function
main "$@"
