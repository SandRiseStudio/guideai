# GuideAI Production Environment Configuration
# Hardened configuration for production workloads

# API Configuration
GUIDEAI_API_URL=https://api.guideai.com
GUIDEAI_API_PORT=8000
GUIDEAI_ENV=production

# Database (HA PostgreSQL cluster)
DATABASE_URL=postgresql://guideai_prod:${DB_PASSWORD}@prod-db.guideai.com:5432/guideai_prod
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30
DUCKDB_PATH=/var/lib/guideai/telemetry_prod.duckdb

# Authentication & Authorization
GUIDEAI_DEVICE_FLOW_CLIENT_ID=guideai-prod-client
GUIDEAI_DEVICE_FLOW_AUTH_URL=https://auth.guideai.com
GUIDEAI_ALLOW_PLAINTEXT_TOKENS=false
GUIDEAI_TOKEN_ENCRYPTION_KEY=${TOKEN_ENCRYPTION_KEY}
GUIDEAI_SESSION_SECRET=${SESSION_SECRET}
MFA_ENFORCEMENT_SCOPES=high_risk,actions.replay,agentauth.manage

# Telemetry & Analytics (Production Kafka cluster)
KAFKA_BOOTSTRAP_SERVERS=prod-kafka-1.guideai.com:9092,prod-kafka-2.guideai.com:9092,prod-kafka-3.guideai.com:9092
KAFKA_TOPIC_TELEMETRY=guideai-telemetry-prod
KAFKA_SASL_MECHANISM=SCRAM-SHA-512
KAFKA_SASL_USERNAME=${KAFKA_USERNAME}
KAFKA_SASL_PASSWORD=${KAFKA_PASSWORD}
KAFKA_SSL_ENABLED=true
TELEMETRY_SINK_TYPE=kafka
TELEMETRY_BATCH_SIZE=100
TELEMETRY_FLUSH_INTERVAL=10s

# Secrets Management (HashiCorp Vault)
TOKEN_STORE_TYPE=keychain
TOKEN_VAULT_URL=https://vault.guideai.com
TOKEN_VAULT_TOKEN=${VAULT_TOKEN}
TOKEN_VAULT_NAMESPACE=guideai/prod
SECRET_ROTATION_INTERVAL=30d

# Feature Flags
ENABLE_MCP_SERVER=true
ENABLE_DEVICE_FLOW=true
ENABLE_ANALYTICS_DASHBOARD=true
ENABLE_COMPLIANCE_AUTOMATION=true
ENABLE_MFA_ENFORCEMENT=true
ENABLE_AUDIT_LOGGING=true

# Logging (Structured JSON to centralized aggregator)
LOG_LEVEL=WARNING
LOG_FORMAT=json
STRUCTURED_LOGGING=true
LOG_AGGREGATOR_URL=https://logs.guideai.com
LOG_AGGREGATOR_API_KEY=${LOG_API_KEY}

# CORS (Strict production origins)
ALLOWED_ORIGINS=https://guideai.com,https://dashboard.guideai.com,https://app.guideai.com

# Rate Limiting (Production thresholds)
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEVICE_FLOW=5/minute  # Stricter per-IP limits
RATE_LIMIT_API=1000/hour
RATE_LIMIT_AUTH_ATTEMPTS=5/5minutes
RATE_LIMIT_STORAGE=redis
REDIS_URL=redis://prod-redis.guideai.com:6379

# Monitoring & Observability
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
METRICS_EXPORT_INTERVAL=15s
GRAFANA_DASHBOARD_URL=https://grafana.guideai.com
ALERTMANAGER_URL=https://alerts.guideai.com

# Security Hardening
ENFORCE_HTTPS=true
HSTS_ENABLED=true
HSTS_MAX_AGE=31536000
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=strict
CSRF_PROTECTION=true
CONTENT_SECURITY_POLICY=default-src 'self'
X_FRAME_OPTIONS=DENY

# Performance & Scaling
WORKER_COUNT=4
WORKER_TIMEOUT=30
KEEPALIVE_TIMEOUT=5
MAX_REQUESTS_PER_WORKER=1000
GRACEFUL_SHUTDOWN_TIMEOUT=30s

# Backup & Disaster Recovery
BACKUP_ENABLED=true
BACKUP_INTERVAL=6h
BACKUP_RETENTION_DAYS=30
BACKUP_STORAGE_URL=s3://guideai-backups-prod

# Compliance & Audit
AUDIT_LOG_RETENTION_DAYS=2555  # 7 years for SOC2/GDPR
GDPR_DATA_RETENTION_DAYS=730
COMPLIANCE_REPORTING_ENABLED=true
PII_ENCRYPTION_ENABLED=true
