# GuideAI Production Environment Configuration
# Last Updated: 2025-11-11
# Purpose: Production deployment with managed services and strict security

# ============================================================================
# Environment Metadata
# ============================================================================
ENVIRONMENT=production
DEPLOY_VERSION=${DEPLOY_VERSION}  # Set via CI/CD pipeline

# ============================================================================
# Multi-Environment Settings (Provider Abstraction)
# ============================================================================

# Storage Provider (AWS S3 for production)
STORAGE__PROVIDER=s3
STORAGE__S3_BUCKET=${GUIDEAI_PRODUCTION_BUCKET}  # From AWS Secrets Manager
STORAGE__S3_REGION=us-east-1
STORAGE__AWS_ACCESS_KEY_ID=${AWS_ACCESS_KEY_ID}  # From Vault/IAM role
STORAGE__AWS_SECRET_ACCESS_KEY=${AWS_SECRET_ACCESS_KEY}  # From Vault/IAM role

# Database Provider (AWS RDS PostgreSQL)
DATABASE__PROVIDER=rds
DATABASE__POSTGRES_URL=${DATABASE_URL}  # From AWS Secrets Manager
DATABASE__POOL_SIZE=20
DATABASE__MAX_OVERFLOW=40
DATABASE__POOL_TIMEOUT=30

# Cache Provider (AWS ElastiCache Redis)
CACHE__PROVIDER=elasticache
CACHE__REDIS_URL=${REDIS_URL}  # From AWS Secrets Manager

# Secrets Provider (AWS Secrets Manager)
SECRETS__PROVIDER=aws-secrets
SECRETS__SECRET_PATH_PREFIX=guideai/production

# Observability Provider (Datadog for production monitoring)
OBSERVABILITY__PROVIDER=datadog
OBSERVABILITY__DATADOG_API_KEY=${DATADOG_API_KEY}  # From Vault
OBSERVABILITY__PROMETHEUS_ENABLED=false
OBSERVABILITY__GRAFANA_ENABLED=false

# ============================================================================
# API Service Configuration
# ============================================================================
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_LOG_LEVEL=info
API_RELOAD=false
API_BASE_URL=https://api.guideai.com

# CORS Settings (production - strict domain whitelist)
CORS_ORIGINS=https://app.guideai.com,https://www.guideai.com
CORS_ALLOW_CREDENTIALS=true

# ============================================================================
# MCP Server Configuration
# ============================================================================
MCP_HOST=0.0.0.0
MCP_PORT=3000
MCP_LOG_LEVEL=info
MCP_TRANSPORT=stdio

# ============================================================================
# Authentication & Security (Production - Strict)
# ============================================================================
JWT_SECRET_KEY=${JWT_SECRET_KEY}  # From AWS Secrets Manager
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Device Flow OAuth (Production - GitHub OAuth App)
OAUTH_CLIENT_ID=${OAUTH_CLIENT_ID}  # From AWS Secrets Manager
OAUTH_CLIENT_SECRET=${OAUTH_CLIENT_SECRET}  # From AWS Secrets Manager
OAUTH_DEVICE_CODE_URL=https://github.com/login/device/code
OAUTH_TOKEN_URL=https://github.com/login/oauth/access_token
OAUTH_USER_URL=https://api.github.com/user

# Session Management (Production - Secure Cookies)
SESSION_SECRET=${SESSION_SECRET}  # From AWS Secrets Manager
SESSION_COOKIE_SECURE=true  # Require HTTPS
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=strict

# ============================================================================
# Embedding Configuration
# ============================================================================
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_ROLLOUT_PERCENTAGE=100

# ============================================================================
# Feature Flags (Production - Gradual Rollout)
# ============================================================================
FEATURE_MULTI_TENANT=true
FEATURE_FINE_TUNING=true
FEATURE_ADVANCED_RETRIEVAL=true
FEATURE_COLLABORATION=true
FEATURE_TRACE_ANALYSIS=true

# ============================================================================
# Telemetry & Analytics (Production - High Volume)
# ============================================================================
TELEMETRY_ENABLED=true
TELEMETRY_WAREHOUSE_DSN=${TIMESCALEDB_URL}  # From AWS Secrets Manager
ANALYTICS_WAREHOUSE_PATH=s3://guideai-analytics-prod/warehouse/

# Kafka Streaming (Production Cluster)
KAFKA_BOOTSTRAP_SERVERS=kafka-1.internal:9093,kafka-2.internal:9093,kafka-3.internal:9093
KAFKA_SECURITY_PROTOCOL=SASL_SSL
KAFKA_SASL_MECHANISM=SCRAM-SHA-256
KAFKA_SASL_USERNAME=${KAFKA_USERNAME}  # From AWS Secrets Manager
KAFKA_SASL_PASSWORD=${KAFKA_PASSWORD}  # From AWS Secrets Manager

# ============================================================================
# Rate Limiting (Production - Strict)
# ============================================================================
RATE_LIMIT_DEVICE_FLOW=10/min
RATE_LIMIT_API=100/min
RATE_LIMIT_MCP=100/min

# ============================================================================
# Logging Configuration (Production - Centralized)
# ============================================================================
LOG_LEVEL=info
LOG_FORMAT=json
LOG_DESTINATION=cloudwatch  # Send to CloudWatch Logs
LOG_GROUP=/aws/ecs/guideai-production
LOG_STREAM=${CONTAINER_ID}

# ============================================================================
# Compliance & Audit (Production - 7 Year Retention)
# ============================================================================
AUDIT_LOG_RETENTION_DAYS=2555  # 7 years
AUDIT_LOG_S3_BUCKET=guideai-audit-logs-prod
AUDIT_LOG_GLACIER_TRANSITION_DAYS=90

# ============================================================================
# High Availability Configuration
# ============================================================================
HEALTH_CHECK_PATH=/health
HEALTH_CHECK_INTERVAL=30
READINESS_PROBE_PATH=/ready
LIVENESS_PROBE_PATH=/live

# Database Connection Pool (Production - High Concurrency)
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# Redis Connection Pool (Production)
REDIS_MAX_CONNECTIONS=50
REDIS_TIMEOUT=5

# ============================================================================
# Monitoring & Alerting
# ============================================================================
PROMETHEUS_PORT=9090
PROMETHEUS_METRICS_PATH=/metrics

# Datadog Integration
DD_TRACE_ENABLED=true
DD_SERVICE=guideai-api
DD_ENV=production
DD_VERSION=${DEPLOY_VERSION}
DD_LOGS_INJECTION=true

# ============================================================================
# Disaster Recovery
# ============================================================================
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *  # Daily at 2 AM UTC
BACKUP_S3_BUCKET=guideai-backups-prod
BACKUP_RETENTION_DAYS=30
BACKUP_CROSS_REGION_REPLICATION=true
BACKUP_CROSS_REGION_BUCKET=guideai-backups-prod-dr

# ============================================================================
# Cost Optimization
# ============================================================================
AUTO_SCALING_ENABLED=true
AUTO_SCALING_MIN_INSTANCES=2
AUTO_SCALING_MAX_INSTANCES=10
AUTO_SCALING_TARGET_CPU=70
AUTO_SCALING_TARGET_MEMORY=80

# Spot Instance Configuration (for non-critical workloads)
USE_SPOT_INSTANCES=false  # Set to true for cost savings on dev/staging
SPOT_MAX_PRICE=0.10

# ============================================================================
# Security Headers
# ============================================================================
HSTS_MAX_AGE=31536000
CSP_POLICY=default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'
X_FRAME_OPTIONS=DENY
X_CONTENT_TYPE_OPTIONS=nosniff
