# GuideAI Staging Environment Configuration
# Mirrors production setup with test data

# API Configuration
GUIDEAI_API_URL=https://staging.guideai.com
GUIDEAI_API_PORT=8000
GUIDEAI_ENV=staging

# Database
DATABASE_URL=postgresql://guideai_staging:${DB_PASSWORD}@staging-db.guideai.com:5432/guideai_staging
DUCKDB_PATH=/var/lib/guideai/telemetry_staging.duckdb

# Authentication
GUIDEAI_DEVICE_FLOW_CLIENT_ID=guideai-staging-client
GUIDEAI_DEVICE_FLOW_AUTH_URL=https://staging-auth.guideai.com
GUIDEAI_ALLOW_PLAINTEXT_TOKENS=false
GUIDEAI_TOKEN_ENCRYPTION_KEY=${TOKEN_ENCRYPTION_KEY}

# Telemetry & Analytics
KAFKA_BOOTSTRAP_SERVERS=staging-kafka.guideai.com:9092
KAFKA_TOPIC_TELEMETRY=guideai-telemetry-staging
KAFKA_SASL_MECHANISM=SCRAM-SHA-256
KAFKA_SASL_USERNAME=${KAFKA_USERNAME}
KAFKA_SASL_PASSWORD=${KAFKA_PASSWORD}
TELEMETRY_SINK_TYPE=kafka

# Secrets Management
TOKEN_STORE_TYPE=keychain
TOKEN_VAULT_URL=https://staging-vault.guideai.com
TOKEN_VAULT_TOKEN=${VAULT_TOKEN}

# Feature Flags
ENABLE_MCP_SERVER=true
ENABLE_DEVICE_FLOW=true
ENABLE_ANALYTICS_DASHBOARD=true
ENABLE_COMPLIANCE_AUTOMATION=true
ENABLE_MFA_ENFORCEMENT=true

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
STRUCTURED_LOGGING=true
LOG_AGGREGATOR_URL=https://logs.guideai.com

# CORS
ALLOWED_ORIGINS=https://staging.guideai.com,https://staging-dashboard.guideai.com

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEVICE_FLOW=10/minute  # Per IP
RATE_LIMIT_API=100/minute

# Monitoring
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
METRICS_EXPORT_INTERVAL=30s

# Security
ENFORCE_HTTPS=true
SESSION_COOKIE_SECURE=true
CSRF_PROTECTION=true
