# GuideAI Telemetry Pipeline - Local Development Configuration
# Source with: set -a; source deployment/config/telemetry.dev.env; set +a

# ==============================================================================
# LLM Provider Configuration (for BCI - Behavior-Conditioned Inference)
# ==============================================================================

# Provider selection: openai, anthropic, openrouter, ollama, together, groq, fireworks, test
GUIDEAI_LLM_PROVIDER=test

# OpenAI Configuration (primary production provider)
# OPENAI_API_KEY=sk-...  # Required for OpenAI provider
GUIDEAI_LLM_MODEL=gpt-4o-mini  # See OPENAI_MODELS in settings.py for options

# Per-request token budget (prevents runaway costs)
GUIDEAI_LLM_TOKEN_BUDGET_ENABLED=true
GUIDEAI_LLM_TOKEN_BUDGET_PER_REQUEST=50000  # Max tokens per BCI request
GUIDEAI_LLM_TOKEN_BUDGET_WARN_THRESHOLD=0.8  # Warn at 80% of budget

# Retry configuration
GUIDEAI_LLM_MAX_RETRIES=3
GUIDEAI_LLM_RETRY_BASE_DELAY=1.0

# Alternative providers (uncomment and configure as needed):
# ANTHROPIC_API_KEY=...           # For Anthropic Claude
# OPENROUTER_API_KEY=...          # For OpenRouter (multi-model)
# TOGETHER_API_KEY=...            # For Together.ai
# GROQ_API_KEY=...                # For Groq
# FIREWORKS_API_KEY=...           # For Fireworks.ai
# OLLAMA_HOST=http://localhost:11434  # For local Ollama

# ==============================================================================
# Kafka Configuration
# ==============================================================================
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_TELEMETRY_EVENTS=telemetry.events
KAFKA_CONSUMER_GROUP=telemetry-kpi-projector
KAFKA_AUTO_OFFSET_RESET=earliest

# Flink Configuration
FLINK_PARALLELISM=2
FLINK_CHECKPOINT_INTERVAL=60000
FLINK_CHECKPOINT_MODE=EXACTLY_ONCE

# Warehouse Configuration
# Phase 1: DuckDB (embedded, zero-cost, local development)
WAREHOUSE_TYPE=duckdb
DUCKDB_PATH=data/telemetry.duckdb

# Phase 2: PostgreSQL + TimescaleDB (production, free open-source)
# Uncomment and configure when moving to production:
# WAREHOUSE_TYPE=postgresql
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DATABASE=guideai
# POSTGRES_USER=guideai_dev
# POSTGRES_PASSWORD=changeme

# Legacy: Snowflake (paid service, optional)
# WAREHOUSE_TYPE=snowflake
# SNOWFLAKE_ACCOUNT=your-dev-account.snowflakecomputing.com
# SNOWFLAKE_USER=guideai_dev
# SNOWFLAKE_PASSWORD=changeme
# SNOWFLAKE_DATABASE=GUIDEAI_DEV
# SNOWFLAKE_SCHEMA=prd_metrics
# SNOWFLAKE_WAREHOUSE=COMPUTE_WH
# SNOWFLAKE_ROLE=ACCOUNTADMIN

# Telemetry Client Configuration
TELEMETRY_SINK=kafka
TELEMETRY_FILE_PATH=/tmp/guideai/telemetry/events.jsonl
TELEMETRY_BATCH_SIZE=100
TELEMETRY_FLUSH_INTERVAL_MS=5000

# Projection Configuration
PROJECTION_WINDOW_SIZE_MINUTES=60
PROJECTION_WATERMARK_DELAY_MS=30000

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
