# Hybrid Flink Architecture Configuration
# Supports both local development (ARM64) and cloud production deployment

# =============================================================================
# LOCAL DEVELOPMENT (ARM64 Compatible)

# Environment selector
DEPLOYMENT_MODE=local

# Kafka Configuration (Local)
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_TELEMETRY_EVENTS=telemetry.events
KAFKA_CONSUMER_GROUP=telemetry-kpi-projector-dev

# Flink Job Configuration (Dev Mode)
FLINK_MODE=dev
FLINK_EXECUTION_MODE=kafka-python
FLINK_CHECKPOINT_DIR=/opt/flink/checkpoints

# Warehouse Configuration (Local DuckDB)
WAREHOUSE_TYPE=duckdb
DUCKDB_PATH=data/telemetry.duckdb

# Processing Configuration
PROJECTION_BATCH_SIZE=1000
PROJECTION_FLUSH_INTERVAL_MS=60000
KAFKA_AUTO_OFFSET_RESET=earliest

# Logging
LOG_LEVEL=INFO

# =============================================================================
# CLOUD PRODUCTION (AWS Kinesis Data Analytics)

# Environment selector (uncomment for production)
# DEPLOYMENT_MODE=cloud

# Kafka Configuration (Cloud)
# KAFKA_BOOTSTRAP_SERVERS=your-msk-broker-1:9092,your-msk-broker-2:9092,your-msk-broker-3:9092
# KAFKA_TOPIC_TELEMETRY_EVENTS=telemetry.events
# KAFKA_CONSUMER_GROUP=telemetry-kpi-projector-prod

# Flink Job Configuration (Prod Mode)
# FLINK_MODE=prod
# FLINK_EXECUTION_MODE=pyflink
# KINESIS_DATA_ANALYTICS_APPLICATION_NAME=guideai-telemetry-kpi

# AWS Configuration
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_SESSION_TOKEN=your-session-token

# Warehouse Configuration (TimescaleDB)
# WAREHOUSE_TYPE=postgresql
# POSTGRES_HOST=your-rds-endpoint.region.rds.amazonaws.com
# POSTGRES_PORT=5432
# POSTGRES_DATABASE=guideai_telemetry
# POSTGRES_USER=guideai_telemetry
# POSTGRES_PASSWORD=your-secure-password

# Processing Configuration (Production)
# PROJECTION_BATCH_SIZE=5000
# PROJECTION_FLUSH_INTERVAL_MS=30000
# KAFKA_AUTO_OFFSET_RESET=latest

# Monitoring
# FLINK_METRICS_ENABLED=true
# CLOUDWATCH_NAMESPACE=GuideAI/Telemetry

# =============================================================================
# Validation Configuration

# Enable cross-environment validation
VALIDATION_MODE=enabled
VALIDATION_COMPARISON_ENABLED=true

# Test data configuration
VALIDATION_TEST_EVENTS=10000
VALIDATION_LATENCY_THRESHOLD_MS=100

# Parity checks
CHECK_KAFKA_OFFSETS=true
CHECK_TIMESERIES_CONSISTENCY=true
CHECK_METRICS_PARITY=true
