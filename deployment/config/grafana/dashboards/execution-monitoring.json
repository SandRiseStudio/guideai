{
  "dashboard": {
    "id": null,
    "uid": "guideai-execution",
    "title": "GuideAI Execution Monitoring",
    "description": "Monitors execution queue, workers, workspaces, and zombie reaper",
    "tags": ["guideai", "execution", "workers", "queue"],
    "timezone": "UTC",
    "schemaVersion": 30,
    "version": 1,
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "refresh": "10s",
    "annotations": {
      "list": []
    },
    "templating": {
      "list": [
        {
          "name": "scope",
          "type": "query",
          "query": "label_values(guideai_execution_jobs_processed_total, scope)",
          "refresh": 2,
          "includeAll": true,
          "multi": true
        }
      ]
    },
    "panels": [
      {
        "id": 1,
        "title": "Execution Overview",
        "type": "row",
        "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
        "collapsed": false
      },
      {
        "id": 2,
        "title": "Jobs Processed (Success)",
        "type": "stat",
        "targets": [
          {
            "expr": "sum(increase(guideai_execution_jobs_processed_total{status=\"success\"}[1h]))",
            "legendFormat": "Success",
            "refId": "A"
          }
        ],
        "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "thresholds" },
            "thresholds": {
              "steps": [
                { "color": "green", "value": null }
              ]
            }
          }
        }
      },
      {
        "id": 3,
        "title": "Jobs Processed (Failed)",
        "type": "stat",
        "targets": [
          {
            "expr": "sum(increase(guideai_execution_jobs_processed_total{status=\"failure\"}[1h]))",
            "legendFormat": "Failed",
            "refId": "A"
          }
        ],
        "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "thresholds" },
            "thresholds": {
              "steps": [
                { "color": "green", "value": null },
                { "color": "yellow", "value": 1 },
                { "color": "red", "value": 5 }
              ]
            }
          }
        }
      },
      {
        "id": 4,
        "title": "Jobs Processed (Timeout)",
        "type": "stat",
        "targets": [
          {
            "expr": "sum(increase(guideai_execution_jobs_processed_total{status=\"timeout\"}[1h]))",
            "legendFormat": "Timeout",
            "refId": "A"
          }
        ],
        "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "thresholds" },
            "thresholds": {
              "steps": [
                { "color": "green", "value": null },
                { "color": "orange", "value": 1 },
                { "color": "red", "value": 3 }
              ]
            }
          }
        }
      },
      {
        "id": 5,
        "title": "Jobs In Progress",
        "type": "stat",
        "targets": [
          {
            "expr": "sum(guideai_execution_jobs_in_progress)",
            "legendFormat": "In Progress",
            "refId": "A"
          }
        ],
        "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "thresholds" },
            "thresholds": {
              "steps": [
                { "color": "blue", "value": null }
              ]
            }
          }
        }
      },
      {
        "id": 6,
        "title": "Active Workspaces",
        "type": "stat",
        "targets": [
          {
            "expr": "sum(guideai_workspaces_active)",
            "legendFormat": "Active",
            "refId": "A"
          }
        ],
        "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "thresholds" },
            "thresholds": {
              "steps": [
                { "color": "blue", "value": null },
                { "color": "yellow", "value": 50 },
                { "color": "red", "value": 100 }
              ]
            }
          }
        }
      },
      {
        "id": 7,
        "title": "Zombies Reaped (1h)",
        "type": "stat",
        "targets": [
          {
            "expr": "sum(increase(guideai_zombies_reaped_total[1h]))",
            "legendFormat": "Zombies",
            "refId": "A"
          }
        ],
        "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "thresholds" },
            "thresholds": {
              "steps": [
                { "color": "green", "value": null },
                { "color": "yellow", "value": 5 },
                { "color": "red", "value": 10 }
              ]
            }
          }
        }
      },
      {
        "id": 8,
        "title": "Queue & Workers",
        "type": "row",
        "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
        "collapsed": false
      },
      {
        "id": 9,
        "title": "Queue Depth by Priority",
        "type": "timeseries",
        "targets": [
          {
            "expr": "guideai_execution_queue_depth",
            "legendFormat": "{{priority}}",
            "refId": "A"
          }
        ],
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
        "fieldConfig": {
          "defaults": {
            "custom": {
              "drawStyle": "line",
              "fillOpacity": 20,
              "lineWidth": 2,
              "spanNulls": true
            }
          }
        }
      },
      {
        "id": 10,
        "title": "Jobs In Progress by Worker",
        "type": "timeseries",
        "targets": [
          {
            "expr": "guideai_execution_jobs_in_progress",
            "legendFormat": "{{worker_id}}",
            "refId": "A"
          }
        ],
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
        "fieldConfig": {
          "defaults": {
            "custom": {
              "drawStyle": "line",
              "fillOpacity": 20,
              "lineWidth": 2,
              "spanNulls": true
            }
          }
        }
      },
      {
        "id": 11,
        "title": "Job Processing Rate",
        "type": "timeseries",
        "targets": [
          {
            "expr": "sum(rate(guideai_execution_jobs_processed_total[5m])) by (status)",
            "legendFormat": "{{status}}",
            "refId": "A"
          }
        ],
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
        "fieldConfig": {
          "defaults": {
            "unit": "ops",
            "custom": {
              "drawStyle": "line",
              "fillOpacity": 20,
              "lineWidth": 2
            }
          }
        }
      },
      {
        "id": 12,
        "title": "Job Duration Distribution",
        "type": "heatmap",
        "targets": [
          {
            "expr": "sum(rate(guideai_execution_job_duration_seconds_bucket[5m])) by (le)",
            "legendFormat": "{{le}}",
            "refId": "A",
            "format": "heatmap"
          }
        ],
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
        "options": {
          "calculate": false,
          "yAxis": {
            "unit": "s"
          }
        }
      },
      {
        "id": 13,
        "title": "Workspaces & Quotas",
        "type": "row",
        "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 },
        "collapsed": false
      },
      {
        "id": 14,
        "title": "Workspaces Provisioned Rate",
        "type": "timeseries",
        "targets": [
          {
            "expr": "sum(rate(guideai_workspaces_provisioned_total[5m])) by (scope)",
            "legendFormat": "{{scope}}",
            "refId": "A"
          }
        ],
        "gridPos": { "h": 8, "w": 8, "x": 0, "y": 23 },
        "fieldConfig": {
          "defaults": {
            "unit": "ops",
            "custom": {
              "drawStyle": "line",
              "fillOpacity": 20,
              "lineWidth": 2
            }
          }
        }
      },
      {
        "id": 15,
        "title": "Workspaces Cleaned by Reason",
        "type": "timeseries",
        "targets": [
          {
            "expr": "sum(rate(guideai_workspaces_cleaned_total[5m])) by (reason)",
            "legendFormat": "{{reason}}",
            "refId": "A"
          }
        ],
        "gridPos": { "h": 8, "w": 8, "x": 8, "y": 23 },
        "fieldConfig": {
          "defaults": {
            "unit": "ops",
            "custom": {
              "drawStyle": "line",
              "fillOpacity": 20,
              "lineWidth": 2
            }
          }
        }
      },
      {
        "id": 16,
        "title": "Quota Usage by Scope",
        "type": "timeseries",
        "targets": [
          {
            "expr": "guideai_quota_usage",
            "legendFormat": "{{scope}}",
            "refId": "A"
          }
        ],
        "gridPos": { "h": 8, "w": 8, "x": 16, "y": 23 },
        "fieldConfig": {
          "defaults": {
            "custom": {
              "drawStyle": "line",
              "fillOpacity": 20,
              "lineWidth": 2
            }
          }
        }
      },
      {
        "id": 17,
        "title": "Quota Rejections",
        "type": "stat",
        "targets": [
          {
            "expr": "sum(increase(guideai_quota_checks_total{result=\"rejected\"}[1h]))",
            "legendFormat": "Rejected",
            "refId": "A"
          }
        ],
        "gridPos": { "h": 4, "w": 6, "x": 0, "y": 31 },
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "thresholds" },
            "thresholds": {
              "steps": [
                { "color": "green", "value": null },
                { "color": "yellow", "value": 1 },
                { "color": "red", "value": 10 }
              ]
            }
          }
        }
      },
      {
        "id": 18,
        "title": "Quota Allowed",
        "type": "stat",
        "targets": [
          {
            "expr": "sum(increase(guideai_quota_checks_total{result=\"allowed\"}[1h]))",
            "legendFormat": "Allowed",
            "refId": "A"
          }
        ],
        "gridPos": { "h": 4, "w": 6, "x": 6, "y": 31 },
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "thresholds" },
            "thresholds": {
              "steps": [
                { "color": "green", "value": null }
              ]
            }
          }
        }
      },
      {
        "id": 19,
        "title": "Zombie Reaper",
        "type": "row",
        "gridPos": { "h": 1, "w": 24, "x": 0, "y": 35 },
        "collapsed": false
      },
      {
        "id": 20,
        "title": "Reaper Run Rate",
        "type": "timeseries",
        "targets": [
          {
            "expr": "rate(guideai_reaper_runs_total[5m])",
            "legendFormat": "Runs",
            "refId": "A"
          },
          {
            "expr": "rate(guideai_reaper_errors_total[5m])",
            "legendFormat": "Errors",
            "refId": "B"
          }
        ],
        "gridPos": { "h": 6, "w": 12, "x": 0, "y": 36 },
        "fieldConfig": {
          "defaults": {
            "unit": "ops",
            "custom": {
              "drawStyle": "line",
              "fillOpacity": 20,
              "lineWidth": 2
            }
          },
          "overrides": [
            {
              "matcher": { "id": "byName", "options": "Errors" },
              "properties": [
                { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }
              ]
            }
          ]
        }
      },
      {
        "id": 21,
        "title": "Zombies Reaped Over Time",
        "type": "timeseries",
        "targets": [
          {
            "expr": "rate(guideai_zombies_reaped_total[5m])",
            "legendFormat": "Zombies/s",
            "refId": "A"
          }
        ],
        "gridPos": { "h": 6, "w": 12, "x": 12, "y": 36 },
        "fieldConfig": {
          "defaults": {
            "unit": "ops",
            "color": { "mode": "fixed", "fixedColor": "orange" },
            "custom": {
              "drawStyle": "line",
              "fillOpacity": 20,
              "lineWidth": 2
            }
          }
        }
      },
      {
        "id": 22,
        "title": "Job Duration Percentiles",
        "type": "row",
        "gridPos": { "h": 1, "w": 24, "x": 0, "y": 42 },
        "collapsed": false
      },
      {
        "id": 23,
        "title": "Job Duration P50/P95/P99",
        "type": "timeseries",
        "targets": [
          {
            "expr": "histogram_quantile(0.50, sum(rate(guideai_execution_job_duration_seconds_bucket[5m])) by (le))",
            "legendFormat": "P50",
            "refId": "A"
          },
          {
            "expr": "histogram_quantile(0.95, sum(rate(guideai_execution_job_duration_seconds_bucket[5m])) by (le))",
            "legendFormat": "P95",
            "refId": "B"
          },
          {
            "expr": "histogram_quantile(0.99, sum(rate(guideai_execution_job_duration_seconds_bucket[5m])) by (le))",
            "legendFormat": "P99",
            "refId": "C"
          }
        ],
        "gridPos": { "h": 8, "w": 24, "x": 0, "y": 43 },
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "custom": {
              "drawStyle": "line",
              "fillOpacity": 10,
              "lineWidth": 2,
              "spanNulls": true
            }
          }
        }
      }
    ]
  },
  "overwrite": true
}
