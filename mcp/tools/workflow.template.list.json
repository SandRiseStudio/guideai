{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "name": "workflow.template.list",
  "description": "List workflow templates with optional filters by role and tags.",
  "inputSchema": {
    "type": "object",
    "properties": {
      "role_focus": {
        "type": "string",
        "enum": ["STRATEGIST", "TEACHER", "STUDENT", "MULTI_ROLE"],
        "description": "Filter templates by primary role"
      },
      "tags": {
        "type": "array",
        "description": "Filter templates containing these tags",
        "items": {"type": "string"}
      }
    },
    "additionalProperties": false
  },
  "outputSchema": {
    "type": "object",
    "required": ["templates"],
    "properties": {
      "templates": {
        "type": "array",
        "items": {
          "type": "object",
          "required": ["template_id", "name", "role_focus", "steps"],
          "properties": {
            "template_id": {"type": "string"},
            "name": {"type": "string"},
            "description": {"type": "string"},
            "role_focus": {"type": "string"},
            "version": {"type": "string"},
            "created_at": {"type": "string", "format": "date-time"},
            "created_by": {"type": "object"},
            "steps": {"type": "array"},
            "tags": {"type": "array", "items": {"type": "string"}},
            "metadata": {"type": "object"}
          }
        }
      }
    }
  }
}
