{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "name": "workItems.listComments",
  "description": "List comments on a work item with pagination support.",
  "inputSchema": {
    "type": "object",
    "properties": {
      "work_item_id": {
        "type": "string",
        "description": "ID or display ID (e.g. 'myproject-42') of the work item to list comments for (required)"
      },
      "limit": {
        "type": "integer",
        "minimum": 1,
        "maximum": 100,
        "default": 50,
        "description": "Maximum number of comments to return"
      },
      "offset": {
        "type": "integer",
        "minimum": 0,
        "default": 0,
        "description": "Number of comments to skip for pagination"
      },
      "org_id": {
        "type": "string",
        "description": "Organization ID for multi-tenant context"
      }
    },
    "required": ["work_item_id"]
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "success": {
        "type": "boolean",
        "description": "Whether the query was successful"
      },
      "comments": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "comment_id": { "type": "string" },
            "work_item_id": { "type": "string" },
            "author_id": { "type": "string" },
            "author_type": { "type": "string" },
            "content": { "type": "string" },
            "run_id": { "type": ["string", "null"] },
            "metadata": { "type": "object" },
            "created_at": { "type": "string", "format": "date-time" },
            "updated_at": { "type": "string", "format": "date-time" }
          }
        },
        "description": "Array of comment objects"
      },
      "count": {
        "type": "integer",
        "description": "Number of comments returned in this response"
      },
      "error": {
        "type": "string",
        "description": "Error message if success is false"
      }
    }
  },
  "examples": [
    {
      "name": "List all comments",
      "input": {
        "work_item_id": "wi_abc123"
      }
    },
    {
      "name": "Paginated comments",
      "input": {
        "work_item_id": "wi_abc123",
        "limit": 10,
        "offset": 20
      }
    }
  ]
}
