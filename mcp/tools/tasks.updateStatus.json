{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "name": "tasks.updateStatus",
  "description": "Update an existing task's status, priority, or metadata. Sets completed_at timestamp when status becomes 'completed'.",
  "inputSchema": {
    "type": "object",
    "required": ["task_id"],
    "properties": {
      "task_id": {
        "type": "string",
        "description": "Task ID to update"
      },
      "status": {
        "type": "string",
        "enum": ["pending", "in_progress", "completed", "failed", "blocked", "cancelled"],
        "description": "New task status"
      },
      "priority": {
        "type": "integer",
        "description": "New priority level: 1=urgent, 2=high, 3=normal, 4=low",
        "minimum": 1,
        "maximum": 4
      },
      "metadata": {
        "type": "object",
        "description": "Updated metadata (JSONB)"
      },
      "completed_at": {
        "type": "string",
        "format": "date-time",
        "description": "Completion timestamp (ISO 8601 format)"
      }
    },
    "additionalProperties": false
  },
  "outputSchema": {
    "type": "object",
    "required": [
      "task_id",
      "agent_id",
      "task_type",
      "status",
      "priority",
      "title"
    ],
    "properties": {
      "task_id": {"type": "string"},
      "agent_id": {"type": "string"},
      "task_type": {"type": "string"},
      "status": {"type": "string"},
      "priority": {"type": "integer"},
      "title": {"type": "string"},
      "description": {"type": ["string", "null"]},
      "behavior_id": {"type": ["string", "null"]},
      "run_id": {"type": ["string", "null"]},
      "metadata": {"type": "object"},
      "created_at": {"type": ["string", "null"], "format": "date-time"},
      "updated_at": {"type": ["string", "null"], "format": "date-time"},
      "completed_at": {"type": ["string", "null"], "format": "date-time"},
      "deadline": {"type": ["string", "null"], "format": "date-time"}
    },
    "additionalProperties": false
  }
}
