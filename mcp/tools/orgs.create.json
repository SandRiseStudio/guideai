{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "name": "orgs.create",
  "description": "Create a new organization. The authenticated user becomes the owner.",
  "inputSchema": {
    "type": "object",
    "properties": {
      "name": {
        "type": "string",
        "minLength": 2,
        "maxLength": 100,
        "description": "Organization display name"
      },
      "slug": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$",
        "minLength": 3,
        "maxLength": 50,
        "description": "URL-safe identifier (auto-generated from name if not provided)"
      },
      "description": {
        "type": "string",
        "maxLength": 500,
        "description": "Organization description"
      },
      "plan": {
        "type": "string",
        "enum": ["FREE", "PROFESSIONAL", "ENTERPRISE"],
        "default": "FREE",
        "description": "Subscription plan"
      },
      "settings": {
        "type": "object",
        "description": "Initial organization settings",
        "properties": {
          "default_project_visibility": {
            "type": "string",
            "enum": ["private", "members", "public"],
            "default": "members"
          },
          "require_2fa": {
            "type": "boolean",
            "default": false
          }
        }
      }
    },
    "required": ["name"]
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "id": {
        "type": "string",
        "description": "New organization ID"
      },
      "name": {
        "type": "string"
      },
      "slug": {
        "type": "string"
      },
      "plan": {
        "type": "string"
      },
      "created_at": {
        "type": "string",
        "format": "date-time"
      },
      "owner_id": {
        "type": "string",
        "description": "ID of the user who created the org (owner)"
      }
    }
  }
}
