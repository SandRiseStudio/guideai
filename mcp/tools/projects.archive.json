{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "name": "projects.archive",
  "description": "Archive a project. Archived projects remain accessible but cannot be modified.",
  "inputSchema": {
    "type": "object",
    "properties": {
      "user_id": {
        "type": "string",
        "description": "ID of the user performing the action (required for authorization)"
      },
      "project_id": {
        "type": "string",
        "description": "Project ID to archive"
      }
    },
    "required": ["user_id", "project_id"]
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "success": {
        "type": "boolean"
      },
      "project": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "status": { "type": "string" },
          "archived_at": { "type": "string", "format": "date-time" }
        }
      },
      "message": { "type": "string" }
    }
  }
}
