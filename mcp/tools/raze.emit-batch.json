{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "name": "raze.emit-batch",
  "description": "Emit multiple structured log entries in a single batch operation. More efficient than individual emit calls for bulk logging.",
  "inputSchema": {
    "type": "object",
    "properties": {
      "logs": {
        "type": "array",
        "minItems": 1,
        "maxItems": 1000,
        "description": "Array of log entries to emit",
        "items": {
          "type": "object",
          "properties": {
            "level": {
              "type": "string",
              "enum": ["trace", "debug", "info", "warning", "error", "critical"],
              "default": "info"
            },
            "message": {
              "type": "string"
            },
            "context": {
              "type": "object",
              "additionalProperties": true
            },
            "run_id": {"type": "string"},
            "behavior_id": {"type": "string"},
            "tags": {
              "type": "array",
              "items": {"type": "string"}
            },
            "timestamp": {
              "type": "string",
              "format": "date-time",
              "description": "Optional custom timestamp (defaults to current time)"
            }
          },
          "required": ["message"]
        }
      }
    },
    "required": ["logs"],
    "additionalProperties": false
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "accepted": {
        "type": "integer",
        "description": "Number of log entries accepted"
      },
      "rejected": {
        "type": "integer",
        "description": "Number of log entries rejected due to validation errors"
      },
      "log_ids": {
        "type": "array",
        "items": {"type": "string"},
        "description": "IDs of accepted log entries"
      },
      "errors": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "index": {"type": "integer"},
            "error": {"type": "string"}
          }
        },
        "description": "Validation errors for rejected entries"
      }
    },
    "required": ["accepted", "rejected"]
  },
  "examples": [
    {
      "input": {
        "logs": [
          {
            "level": "info",
            "message": "Step 1 completed",
            "run_id": "run_abc123"
          },
          {
            "level": "debug",
            "message": "Intermediate result",
            "context": {"value": 42}
          }
        ]
      },
      "output": {
        "accepted": 2,
        "rejected": 0,
        "log_ids": ["log_001", "log_002"],
        "errors": []
      }
    }
  ]
}
