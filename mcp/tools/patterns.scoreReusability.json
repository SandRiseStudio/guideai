{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "name": "patterns.scoreReusability",
  "description": "Score a pattern's reusability using PRD formula (0.4*frequency + 0.3*savings + 0.3*applicability). Evaluates frequency score (pattern_frequency/total_runs), token savings score (tokens_saved*frequency / total_corpus_tokens), and applicability score (unique_task_types/total_task_types). Returns overall_score with approval threshold check (>0.7).",
  "inputSchema": {
    "type": "object",
    "required": ["pattern_id", "total_runs", "avg_trace_tokens", "unique_task_types", "total_task_types"],
    "properties": {
      "pattern_id": {
        "type": "string",
        "description": "Pattern identifier to score (from detectPatterns output)."
      },
      "total_runs": {
        "type": "integer",
        "description": "Total runs in analysis period (for frequency normalization).",
        "minimum": 1
      },
      "avg_trace_tokens": {
        "type": "number",
        "description": "Average tokens per trace in corpus (for savings calculation).",
        "minimum": 0
      },
      "unique_task_types": {
        "type": "integer",
        "description": "Number of distinct task types where pattern occurred (e.g., debugging, refactoring, testing).",
        "minimum": 0
      },
      "total_task_types": {
        "type": "integer",
        "description": "Total task types in corpus (for applicability score).",
        "minimum": 1
      }
    },
    "additionalProperties": false
  },
  "outputSchema": {
    "type": "object",
    "required": ["score", "pattern", "meets_threshold"],
    "properties": {
      "score": {
        "type": "object",
        "required": ["pattern_id", "frequency_score", "token_savings_score", "applicability_score", "overall_score", "calculated_at"],
        "properties": {
          "pattern_id": {
            "type": "string",
            "description": "Pattern identifier (matches input)."
          },
          "frequency_score": {
            "type": "number",
            "description": "Normalized frequency score (0-1): pattern_frequency / total_runs."
          },
          "token_savings_score": {
            "type": "number",
            "description": "Token savings score (0-1): (pattern_tokens * frequency) / (avg_trace_tokens * total_runs)."
          },
          "applicability_score": {
            "type": "number",
            "description": "Cross-task applicability score (0-1): unique_task_types / total_task_types."
          },
          "overall_score": {
            "type": "number",
            "description": "Weighted average: 0.4*frequency + 0.3*savings + 0.3*applicability."
          },
          "calculated_at": {
            "type": "string",
            "format": "date-time",
            "description": "ISO timestamp when score was calculated."
          },
          "metadata": {
            "type": "object",
            "description": "Detailed metrics used in calculation (pattern_tokens, potential_savings, etc.)."
          }
        }
      },
      "pattern": {
        "type": "object",
        "description": "Reference pattern details for convenience.",
        "required": ["pattern_id", "sequence", "frequency", "first_seen", "last_seen"],
        "properties": {
          "pattern_id": {"type": "string"},
          "sequence": {
            "type": "array",
            "items": {"type": "string"}
          },
          "frequency": {"type": "integer"},
          "first_seen": {"type": "string", "format": "date-time"},
          "last_seen": {"type": "string", "format": "date-time"},
          "extracted_from_runs": {
            "type": "array",
            "items": {"type": "string"}
          },
          "metadata": {"type": "object"}
        }
      },
      "meets_threshold": {
        "type": "boolean",
        "description": "Whether overall_score exceeds PRD approval threshold (0.7) for candidate generation."
      }
    },
    "additionalProperties": false
  }
}
