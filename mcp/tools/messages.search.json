{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "name": "messages.search",
  "description": "Full-text search messages within a conversation using PostgreSQL tsvector.",
  "inputSchema": {
    "type": "object",
    "properties": {
      "conversation_id": {
        "type": "string",
        "description": "Conversation ID to search within (required)"
      },
      "query": {
        "type": "string",
        "description": "Search query text (required)"
      },
      "user_id": {
        "type": "string",
        "description": "ID of the requesting user"
      },
      "org_id": {
        "type": "string",
        "description": "Optional organization ID for multi-tenant context"
      },
      "limit": {
        "type": "integer",
        "default": 20,
        "minimum": 1,
        "maximum": 100,
        "description": "Maximum number of results to return"
      },
      "offset": {
        "type": "integer",
        "default": 0,
        "minimum": 0,
        "description": "Number of results to skip for pagination"
      }
    },
    "required": ["conversation_id", "query"]
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "success": { "type": "boolean" },
      "results": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "message": { "type": "object" },
            "rank": { "type": "number" },
            "headline": { "type": "string" }
          }
        }
      },
      "total": { "type": "integer" },
      "query": { "type": "string" }
    }
  }
}
