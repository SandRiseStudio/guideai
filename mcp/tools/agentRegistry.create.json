{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "name": "agentRegistry.create",
  "description": "Create a new agent in the registry. Returns the created agent with status=DRAFT and version=1.",
  "inputSchema": {
    "type": "object",
    "properties": {
      "name": {
        "type": "string",
        "description": "Agent name (concise, descriptive)"
      },
      "description": {
        "type": "string",
        "description": "Brief description of what the agent does"
      },
      "mission": {
        "type": "string",
        "description": "The agent's mission statement defining its purpose"
      },
      "role_alignment": {
        "type": "string",
        "enum": ["STRATEGIST", "TEACHER", "STUDENT"],
        "description": "Primary role this agent aligns with"
      },
      "visibility": {
        "type": "string",
        "enum": ["PRIVATE", "TEAM", "ORG", "PUBLIC"],
        "default": "PRIVATE",
        "description": "Visibility level for the agent"
      },
      "capabilities": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "description": "List of capabilities the agent provides"
      },
      "default_behaviors": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "description": "Default behavior IDs to apply when agent is activated"
      },
      "tags": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "description": "Tags for categorization and filtering"
      },
      "metadata": {
        "type": "object",
        "additionalProperties": true,
        "description": "Additional metadata"
      },
      "actor_id": {
        "type": "string",
        "description": "User ID creating the agent"
      }
    },
    "required": ["name", "description", "mission", "role_alignment", "actor_id"]
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "agent_id": {
        "type": "string",
        "description": "Generated agent identifier"
      },
      "name": {
        "type": "string"
      },
      "description": {
        "type": "string"
      },
      "mission": {
        "type": "string"
      },
      "role_alignment": {
        "type": "string",
        "enum": ["STRATEGIST", "TEACHER", "STUDENT"]
      },
      "status": {
        "type": "string",
        "enum": ["DRAFT"],
        "description": "Always DRAFT for newly created agents"
      },
      "visibility": {
        "type": "string",
        "enum": ["PRIVATE", "TEAM", "ORG", "PUBLIC"]
      },
      "version": {
        "type": "integer",
        "description": "Always 1 for newly created agents"
      },
      "capabilities": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "default_behaviors": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "tags": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "builtin": {
        "type": "boolean",
        "description": "Always false for user-created agents"
      },
      "owner_id": {
        "type": "string"
      },
      "created_at": {
        "type": "string",
        "format": "date-time"
      },
      "updated_at": {
        "type": "string",
        "format": "date-time"
      },
      "metadata": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "required": ["agent_id", "name", "status", "version", "created_at"]
  }
}
