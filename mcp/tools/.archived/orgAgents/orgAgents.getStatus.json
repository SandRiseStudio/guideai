{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "name": "orgAgents.getStatus",
  "description": "Get the current status and health of an agent including recent activity.",
  "inputSchema": {
    "type": "object",
    "properties": {
      "user_id": {
        "type": "string",
        "description": "ID of the user performing the action (required for authorization)"
      },
      "agent_id": {
        "type": "string",
        "description": "Agent ID to get status for"
      }
    },
    "required": ["user_id", "agent_id"]
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "success": {
        "type": "boolean"
      },
      "status": {
        "type": "object",
        "properties": {
          "agent_id": { "type": "string" },
          "status": { "type": "string", "enum": ["initializing", "idle", "running", "paused", "stopped", "error", "deleted"] },
          "health": { "type": "string", "enum": ["healthy", "degraded", "unhealthy", "unknown"] },
          "current_run_id": { "type": "string" },
          "last_activity_at": { "type": "string", "format": "date-time" },
          "uptime_seconds": { "type": "integer" },
          "error_message": { "type": "string" },
          "resource_usage": {
            "type": "object",
            "properties": {
              "memory_mb": { "type": "number" },
              "cpu_percent": { "type": "number" }
            }
          }
        }
      }
    }
  }
}
