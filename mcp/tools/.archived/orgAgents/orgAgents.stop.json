{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "name": "orgAgents.stop",
  "description": "Stop a running agent. Agent will need to be restarted.",
  "inputSchema": {
    "type": "object",
    "properties": {
      "user_id": {
        "type": "string",
        "description": "ID of the user performing the action (required for authorization)"
      },
      "agent_id": {
        "type": "string",
        "description": "Agent ID to stop"
      },
      "reason": {
        "type": "string",
        "description": "Reason for stopping the agent"
      },
      "force": {
        "type": "boolean",
        "default": false,
        "description": "Force stop without graceful shutdown"
      }
    },
    "required": ["user_id", "agent_id"]
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "success": {
        "type": "boolean"
      },
      "agent": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "status": { "type": "string" },
          "stopped_at": { "type": "string", "format": "date-time" }
        }
      },
      "message": { "type": "string" }
    }
  }
}
