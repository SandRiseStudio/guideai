{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "name": "orgAgents.pause",
  "description": "Pause a running agent. Agent can be resumed later.",
  "inputSchema": {
    "type": "object",
    "properties": {
      "user_id": {
        "type": "string",
        "description": "ID of the user performing the action (required for authorization)"
      },
      "agent_id": {
        "type": "string",
        "description": "Agent ID to pause"
      },
      "reason": {
        "type": "string",
        "description": "Reason for pausing the agent"
      }
    },
    "required": ["user_id", "agent_id"]
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "success": {
        "type": "boolean"
      },
      "agent": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "status": { "type": "string" },
          "paused_at": { "type": "string", "format": "date-time" }
        }
      },
      "message": { "type": "string" }
    }
  }
}
