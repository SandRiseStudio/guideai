{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "name": "telemetry.query",
  "description": "Query telemetry events from the telemetry system. Supports filtering by event type, time range, correlation IDs (run_id, action_id, session_id), actor surface, log level, and full-text search. Returns paginated results.",
  "inputSchema": {
    "type": "object",
    "properties": {
      "event_type": {
        "type": "string",
        "description": "Filter by specific event type (e.g., 'behavior_retrieved', 'run_started')"
      },
      "start_time": {
        "type": "string",
        "format": "date-time",
        "description": "Start of time range (ISO 8601). Supports relative format like '7d', '24h'. Defaults to 7 days ago."
      },
      "end_time": {
        "type": "string",
        "format": "date-time",
        "description": "End of time range (ISO 8601). Defaults to now."
      },
      "run_id": {
        "type": "string",
        "description": "Filter by execution run ID"
      },
      "action_id": {
        "type": "string",
        "description": "Filter by action ID"
      },
      "session_id": {
        "type": "string",
        "description": "Filter by session ID"
      },
      "actor_surface": {
        "type": "string",
        "enum": ["api", "cli", "vscode", "web", "mcp", "system"],
        "description": "Filter by actor surface"
      },
      "level": {
        "type": "string",
        "enum": ["TRACE", "DEBUG", "INFO", "WARNING", "ERROR", "CRITICAL"],
        "description": "Minimum log level to include"
      },
      "search": {
        "type": "string",
        "description": "Full-text search in message field"
      },
      "limit": {
        "type": "integer",
        "minimum": 1,
        "maximum": 10000,
        "default": 100,
        "description": "Maximum number of events to return"
      },
      "offset": {
        "type": "integer",
        "minimum": 0,
        "default": 0,
        "description": "Number of events to skip for pagination"
      }
    },
    "additionalProperties": false
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "events": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "event_id": {"type": "string"},
            "event_type": {"type": "string"},
            "timestamp": {"type": "string", "format": "date-time"},
            "level": {"type": "string"},
            "service": {"type": "string"},
            "message": {"type": "string"},
            "run_id": {"type": ["string", "null"]},
            "action_id": {"type": ["string", "null"]},
            "session_id": {"type": ["string", "null"]},
            "actor": {
              "type": "object",
              "properties": {
                "id": {"type": "string"},
                "role": {"type": "string"},
                "surface": {"type": "string"}
              }
            },
            "payload": {"type": "object"},
            "schema_version": {"type": "string"}
          }
        },
        "description": "Matching telemetry events"
      },
      "total": {
        "type": "integer",
        "description": "Total number of matching events (before pagination)"
      },
      "limit": {
        "type": "integer",
        "description": "Limit used in query"
      },
      "offset": {
        "type": "integer",
        "description": "Offset used in query"
      }
    },
    "required": ["events", "total", "limit", "offset"]
  },
  "examples": [
    {
      "name": "Query behavior events for last 24 hours",
      "input": {
        "event_type": "behavior_retrieved",
        "start_time": "24h",
        "limit": 50
      },
      "output": {
        "events": [
          {
            "event_id": "evt-550e8400-e29b-41d4",
            "event_type": "behavior_retrieved",
            "timestamp": "2024-01-15T10:30:00Z",
            "level": "INFO",
            "service": "behavior-service",
            "message": "Retrieved behavior for task",
            "run_id": "run-xyz789",
            "actor": {
              "id": "user-123",
              "role": "Student",
              "surface": "vscode"
            },
            "payload": {"behavior_id": "behavior_use_raze_for_logging", "relevance_score": 0.92},
            "schema_version": "v1"
          }
        ],
        "total": 1,
        "limit": 50,
        "offset": 0
      }
    },
    {
      "name": "Query all events for a specific run",
      "input": {
        "run_id": "run-abc123",
        "limit": 200
      },
      "output": {
        "events": [],
        "total": 0,
        "limit": 200,
        "offset": 0
      }
    },
    {
      "name": "Search for error events",
      "input": {
        "level": "ERROR",
        "search": "timeout",
        "limit": 25
      },
      "output": {
        "events": [],
        "total": 0,
        "limit": 25,
        "offset": 0
      }
    }
  ]
}
