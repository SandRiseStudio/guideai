{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "name": "retrieval.advanced-search",
  "description": "Perform advanced semantic search with reranking, query expansion, and contextual embeddings.",
  "inputSchema": {
    "type": "object",
    "properties": {
      "query": {
        "type": "string",
        "description": "Search query text"
      },
      "search_type": {
        "type": "string",
        "enum": ["SEMANTIC", "HYBRID", "KEYWORD", "MULTI_STAGE"],
        "description": "Type of search to perform"
      },
      "query_expansion": {
        "type": "object",
        "description": "Query expansion configuration",
        "properties": {
          "method": {
            "type": "string",
            "enum": ["SYNONYM", "SEMANTIC", "NEURAL", "NONE"]
          },
          "max_expansions": {
            "type": "integer",
            "default": 5
          }
        }
      },
      "reranking": {
        "type": "object",
        "description": "Reranking configuration",
        "properties": {
          "model": {
            "type": "string",
            "enum": ["CROSS_ENCODER", "COLBERT", "MINILM"]
          },
          "top_k": {
            "type": "integer",
            "default": 50
          }
        }
      },
      "context_config": {
        "type": "object",
        "description": "Contextual embedding configuration",
        "properties": {
          "user_profile": {
            "type": "object"
          },
          "session_context": {
            "type": "object"
          },
          "personalization_weight": {
            "type": "number",
            "default": 0.3
          }
        }
      }
    },
    "required": ["query", "search_type"]
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "results": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "item_id": {
              "type": "string"
            },
            "title": {
              "type": "string"
            },
            "content": {
              "type": "string"
            },
            "score": {
              "type": "number"
            },
            "rerank_score": {
              "type": "number"
            },
            "match_type": {
              "type": "string"
            },
            "explanation": {
              "type": "string"
            }
          }
        }
      },
      "query_metadata": {
        "type": "object",
        "properties": {
          "original_query": {
            "type": "string"
          },
          "expanded_queries": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "search_metrics": {
            "type": "object",
            "properties": {
              "retrieval_time_ms": {
                "type": "number"
              },
              "reranking_time_ms": {
                "type": "number"
              },
              "total_results": {
                "type": "integer"
              },
              "confidence_score": {
                "type": "number"
              }
            }
          }
        }
      }
    },
    "required": ["results", "query_metadata"]
  }
}
