{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "name": "orgs.addMember",
  "description": "Add a member to an organization with a specified role. Requires admin or owner role.",
  "inputSchema": {
    "type": "object",
    "properties": {
      "user_id": {
        "type": "string",
        "description": "ID of the user performing the action (required for authorization)"
      },
      "org_id": {
        "type": "string",
        "description": "Organization ID"
      },
      "target_user_id": {
        "type": "string",
        "description": "ID of the user to add as a member"
      },
      "role": {
        "type": "string",
        "enum": ["owner", "admin", "member", "viewer"],
        "default": "member",
        "description": "Role to assign to the new member"
      }
    },
    "required": ["user_id", "org_id", "target_user_id"]
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "success": {
        "type": "boolean"
      },
      "membership": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "org_id": { "type": "string" },
          "user_id": { "type": "string" },
          "role": { "type": "string" },
          "created_at": { "type": "string", "format": "date-time" }
        }
      },
      "message": { "type": "string" }
    }
  }
}
