{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "name": "orgs.delete",
  "description": "Soft-delete an organization. Requires owner role. Organization can be restored within retention period.",
  "inputSchema": {
    "type": "object",
    "properties": {
      "user_id": {
        "type": "string",
        "description": "ID of the user performing the action (required for authorization)"
      },
      "org_id": {
        "type": "string",
        "description": "Organization ID to delete"
      }
    },
    "required": ["user_id", "org_id"]
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "success": {
        "type": "boolean"
      },
      "org_id": {
        "type": "string"
      },
      "message": { "type": "string" }
    }
  }
}
