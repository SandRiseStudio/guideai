{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "name": "conversations.get",
  "description": "Get a specific conversation by ID, including participant count and last activity.",
  "inputSchema": {
    "type": "object",
    "properties": {
      "conversation_id": {
        "type": "string",
        "description": "Conversation ID to retrieve (required)"
      },
      "user_id": {
        "type": "string",
        "description": "ID of the requesting user"
      },
      "org_id": {
        "type": "string",
        "description": "Optional organization ID for multi-tenant context"
      }
    },
    "required": ["conversation_id"]
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "success": { "type": "boolean" },
      "conversation": { "type": "object" }
    }
  }
}
