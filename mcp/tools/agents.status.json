{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "name": "agents.status",
  "description": "Retrieve current agent assignment status, including active agent, assignment history, heuristics applied, and recommended next agent based on run context. Requires agents.read scope.",
  "inputSchema": {
    "type": "object",
    "properties": {
      "assignment_id": {
        "type": "string",
        "description": "Agent assignment identifier to look up (exclusive with run_id)"
      },
      "run_id": {
        "type": "string",
        "description": "Run identifier to find assignment for (exclusive with assignment_id)"
      }
    },
    "oneOf": [
      {
        "required": ["assignment_id"]
      },
      {
        "required": ["run_id"]
      }
    ]
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "assignment_id": {
        "type": "string",
        "description": "Agent assignment identifier"
      },
      "run_id": {
        "type": "string",
        "description": "Associated run identifier"
      },
      "current_agent_id": {
        "type": "string",
        "description": "Currently active agent identifier"
      },
      "stage": {
        "type": "string",
        "description": "Current workflow stage"
      },
      "status": {
        "type": "string",
        "enum": ["ACTIVE", "COMPLETED", "SUSPENDED", "FAILED"],
        "description": "Assignment status"
      },
      "assignment_history": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "agent_id": { "type": "string" },
            "stage": { "type": "string" },
            "switched_at": { "type": "string", "format": "date-time" },
            "reason": { "type": "string" }
          }
        },
        "description": "History of agent switches for this assignment"
      },
      "recommended_next_agent": {
        "type": "object",
        "properties": {
          "agent_id": { "type": "string" },
          "confidence": { "type": "number" },
          "reason": { "type": "string" }
        },
        "description": "Heuristic-based recommendation for next agent"
      },
      "created_at": {
        "type": "string",
        "format": "date-time",
        "description": "ISO 8601 timestamp of assignment creation"
      },
      "updated_at": {
        "type": "string",
        "format": "date-time",
        "description": "ISO 8601 timestamp of last update"
      }
    },
    "required": ["assignment_id", "current_agent_id", "stage", "status"]
  }
}
