{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "name": "projects.create",
  "description": "Create a new project. If org_id is provided, creates an organization project (requires member role). If org_id is omitted, creates a personal project owned by the user.",
  "inputSchema": {
    "type": "object",
    "properties": {
      "user_id": {
        "type": "string",
        "description": "ID of the user performing the action (auto-injected from session if authenticated)"
      },
      "org_id": {
        "type": "string",
        "description": "Organization ID to create the project in (optional - omit for personal projects)"
      },
      "name": {
        "type": "string",
        "minLength": 1,
        "maxLength": 255,
        "description": "Project name"
      },
      "description": {
        "type": "string",
        "maxLength": 1000,
        "description": "Project description"
      },
      "visibility": {
        "type": "string",
        "enum": ["public", "internal", "private"],
        "default": "private",
        "description": "Project visibility level"
      },
      "settings": {
        "type": "object",
        "description": "Project-specific settings"
      },
      "metadata": {
        "type": "object",
        "description": "Additional metadata for the project"
      }
    },
    "required": ["name"]
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "success": {
        "type": "boolean"
      },
      "project": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "org_id": { "type": "string" },
          "name": { "type": "string" },
          "slug": { "type": "string" },
          "description": { "type": "string" },
          "visibility": { "type": "string" },
          "created_by": { "type": "string" },
          "created_at": { "type": "string", "format": "date-time" }
        }
      },
      "message": { "type": "string" }
    }
  }
}
