{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "name": "tasks.listAssignments",
  "description": "List remaining milestone tasks mapped to functions and agents for planning parity.",
  "inputSchema": {
    "type": "object",
    "properties": {
      "function": {
        "type": "string",
        "description": "Optional function filter (engineering, developer-experience, devops, product, pm, product-analytics, copywriting, compliance)."
      }
    },
    "additionalProperties": false
  },
  "outputSchema": {
    "type": "object",
    "required": ["tasks"],
    "properties": {
      "tasks": {
        "type": "array",
        "items": {
          "type": "object",
          "required": [
            "task_id",
            "title",
            "milestone",
            "status",
            "function",
            "primary_agent",
            "agent_playbook",
            "surfaces"
          ],
          "properties": {
            "task_id": {"type": "string"},
            "title": {"type": "string"},
            "milestone": {"type": "string"},
            "status": {"type": "string"},
            "description": {"type": "string"},
            "function": {"type": "string"},
            "primary_agent": {"type": "string"},
            "agent_playbook": {"type": "string"},
            "surfaces": {
              "type": "array",
              "items": {"type": "string", "enum": ["platform", "cli", "api", "mcp"]}
            },
            "dependencies": {
              "type": "array",
              "items": {"type": "string"}
            },
            "evidence_targets": {
              "type": "array",
              "items": {"type": "string"}
            },
            "supporting_agents": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["function", "primary_agent", "agent_playbook"],
                "properties": {
                  "function": {"type": "string"},
                  "primary_agent": {"type": "string"},
                  "agent_playbook": {"type": "string"},
                  "notes": {"type": "string"}
                },
                "additionalProperties": false
              }
            }
          },
          "additionalProperties": false
        }
      }
    },
    "additionalProperties": false
  }
}
