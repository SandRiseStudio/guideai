{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "name": "tasks.listAssignments",
  "description": "List agent task assignments with optional filters (agent_id, status, task_type, behavior_id, run_id). Returns tasks ordered by priority (urgent first) and creation time.",
  "inputSchema": {
    "type": "object",
    "properties": {
      "agent_id": {
        "type": "string",
        "description": "Optional agent ID filter (e.g., 'agent-engineering-01')"
      },
      "status": {
        "type": "string",
        "enum": ["pending", "in_progress", "completed", "failed", "blocked", "cancelled"],
        "description": "Optional status filter"
      },
      "task_type": {
        "type": "string",
        "enum": ["behavior_review", "compliance_audit", "run_execution", "code_review", "documentation", "testing"],
        "description": "Optional task type filter"
      },
      "behavior_id": {
        "type": "string",
        "description": "Optional behavior ID filter"
      },
      "run_id": {
        "type": "string",
        "description": "Optional run ID filter"
      },
      "limit": {
        "type": "integer",
        "description": "Maximum number of tasks to return (default: 50)",
        "default": 50,
        "minimum": 1,
        "maximum": 500
      }
    },
    "additionalProperties": false
  },
  "outputSchema": {
    "type": "object",
    "required": ["tasks", "total"],
    "properties": {
      "tasks": {
        "type": "array",
        "items": {
          "type": "object",
          "required": [
            "task_id",
            "agent_id",
            "task_type",
            "status",
            "priority",
            "title"
          ],
          "properties": {
            "task_id": {"type": "string"},
            "agent_id": {"type": "string"},
            "task_type": {"type": "string"},
            "status": {"type": "string"},
            "priority": {"type": "integer", "minimum": 1, "maximum": 4},
            "title": {"type": "string"},
            "description": {"type": ["string", "null"]},
            "behavior_id": {"type": ["string", "null"]},
            "run_id": {"type": ["string", "null"]},
            "metadata": {"type": "object"},
            "created_at": {"type": ["string", "null"], "format": "date-time"},
            "updated_at": {"type": ["string", "null"], "format": "date-time"},
            "completed_at": {"type": ["string", "null"], "format": "date-time"},
            "deadline": {"type": ["string", "null"], "format": "date-time"}
          },
          "additionalProperties": false
        }
      },
      "total": {
        "type": "integer",
        "description": "Total number of tasks returned"
      }
    },
    "additionalProperties": false
  }
}
