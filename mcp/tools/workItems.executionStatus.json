{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "name": "workItems.executionStatus",
  "description": "Get the current execution status of a work item, including phase, progress, metrics, and any pending clarifications.",
  "inputSchema": {
    "type": "object",
    "properties": {
      "work_item_id": {
        "type": "string",
        "description": "ID of the work item (required)"
      },
      "org_id": {
        "type": "string",
        "description": "Organization ID (optional)"
      },
      "project_id": {
        "type": "string",
        "description": "Project ID (required)"
      }
    },
    "required": ["work_item_id", "project_id"]
  },
  "output": {
    "description": "Returns detailed execution status",
    "type": "object",
    "properties": {
      "run_id": {
        "type": "string"
      },
      "status": {
        "type": "string",
        "enum": ["PENDING", "RUNNING", "PAUSED", "COMPLETED", "FAILED", "CANCELLED"]
      },
      "phase": {
        "type": "string",
        "description": "Current GEP phase (PLANNING, CLARIFYING, ARCHITECTING, EXECUTING, TESTING, FIXING, VERIFYING, COMPLETING)"
      },
      "progress_percent": {
        "type": "number"
      },
      "started_at": {
        "type": "string",
        "format": "date-time"
      },
      "completed_at": {
        "type": "string",
        "format": "date-time"
      },
      "metrics": {
        "type": "object",
        "properties": {
          "total_iterations": {
            "type": "integer"
          },
          "llm_calls": {
            "type": "integer"
          },
          "tokens_used": {
            "type": "integer"
          }
        }
      },
      "pending_clarification": {
        "type": "object",
        "description": "Present if execution is paused awaiting clarification"
      }
    }
  }
}
