{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "name": "board.filterItems",
  "description": "Filter work items by labels, sprint, status, assignee, and other criteria. Returns items matching ANY of the specified labels (OR semantics).",
  "inputSchema": {
    "type": "object",
    "properties": {
      "project_id": {
        "type": "string",
        "description": "Filter by project ID"
      },
      "board_id": {
        "type": "string",
        "description": "Filter by board ID"
      },
      "labels": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "description": "Filter by label names (OR semantics - items with ANY of these labels)"
      },
      "sprint_id": {
        "type": "string",
        "description": "Filter by sprint ID"
      },
      "item_type": {
        "type": "string",
        "enum": ["epic", "story", "task"],
        "description": "Filter by work item type"
      },
      "status": {
        "type": "string",
        "enum": ["backlog", "ready", "in_progress", "review", "done", "blocked"],
        "description": "Filter by status"
      },
      "assignee_id": {
        "type": "string",
        "description": "Filter by assignee ID"
      },
      "parent_id": {
        "type": "string",
        "description": "Filter by parent item ID (get children)"
      },
      "limit": {
        "type": "integer",
        "description": "Max items to return (1-100)",
        "default": 50,
        "minimum": 1,
        "maximum": 100
      },
      "offset": {
        "type": "integer",
        "description": "Items to skip for pagination",
        "default": 0,
        "minimum": 0
      },
      "org_id": {
        "type": "string",
        "description": "Optional organization ID for multi-tenant context"
      }
    }
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "items": {
        "type": "array",
        "description": "List of matching work items",
        "items": {
          "type": "object",
          "properties": {
            "id": {
              "type": "string",
              "description": "Work item ID"
            },
            "title": {
              "type": "string",
              "description": "Work item title"
            },
            "item_type": {
              "type": "string",
              "enum": ["epic", "story", "task"],
              "description": "Type of work item"
            },
            "status": {
              "type": "string",
              "description": "Current status"
            },
            "priority": {
              "type": "string",
              "description": "Priority level"
            },
            "labels": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "Labels attached to this item"
            },
            "sprint_id": {
              "type": "string",
              "description": "Sprint ID if assigned"
            },
            "assignee_id": {
              "type": "string",
              "description": "Assignee ID"
            },
            "assignee_type": {
              "type": "string",
              "enum": ["user", "agent"],
              "description": "Whether assignee is a user or agent"
            }
          }
        }
      },
      "total": {
        "type": "integer",
        "description": "Total count of matching items"
      },
      "has_more": {
        "type": "boolean",
        "description": "Whether there are more items beyond this page"
      }
    }
  }
}
