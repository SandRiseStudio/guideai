{
	"name": "guideai-ide-extension",
	"displayName": "GuideAI IDE Extension",
	"description": "GuideAI IDE extension with real-time run monitoring, behavior management, and AI agent orchestration for development workflows",
	"version": "1.0.0",
	"publisher": "guideai",
	"repository": {
		"type": "git",
		"url": "https://github.com/SandRiseStudio/guideai"
	},
	"homepage": "https://github.com/SandRiseStudio/guideai",
	"bugs": {
		"url": "https://github.com/SandRiseStudio/guideai/issues"
	},
	"engines": {
		"vscode": "^1.74.0"
	},
	"categories": [
		"Machine Learning",
		"Extension Packs"
	],
	"keywords": [
		"ai",
		"machine-learning",
		"agents",
		"automation",
		"workflows",
		"compliance",
		"behavior-management",
		"mcp",
		"model-context-protocol"
	],
	"icon": "resources/icon.png",
	"badges": [
		{
			"url": "https://img.shields.io/github/v/release/SandRiseStudio/guideai?label=version",
			"href": "https://github.com/SandRiseStudio/guideai/releases",
			"description": "Latest Release"
		},
		{
			"url": "https://img.shields.io/github/workflow/status/SandRiseStudio/guideai/CI?label=build",
			"href": "https://github.com/SandRiseStudio/guideai/actions/workflows/ci.yml",
			"description": "Build Status"
		}
	],
	"license": "Apache-2.0",
	"galleryBanner": {
		"color": "#1e1e1e",
		"theme": "dark"
	},
	"markdown": "github",
	"qna": "https://github.com/SandRiseStudio/guideai/discussions",
	"pricing": "Free",
	"activationEvents": [
		"onStartupFinished"
	],
	"main": "./out/extension.js",
	"contributes": {
		"viewsContainers": {
			"activitybar": [
				{
					"id": "guideai",
					"title": "GuideAI",
					"icon": "resources/guideai-icon.svg"
				}
			]
		},
		"views": {
			"guideai": [
				{
					"id": "guideai.executionTracker",
					"name": "Execution Tracker"
				},
				{
					"id": "guideai.complianceTracker",
					"name": "Compliance Tracker"
				},
				{
					"id": "guideai.actionTracker",
					"name": "Action Registry"
				},
				{
					"id": "guideai.costTracker",
					"name": "Cost Analytics"
				},
				{
					"id": "guideai.behaviorAccuracy",
					"name": "Behavior Accuracy"
				},
				{
					"id": "guideai.conversations",
					"name": "Conversations"
				}
			]
		},
		"commands": [
			{
				"command": "guideai.refreshExecutionTracker",
				"title": "Refresh Execution Tracker",
				"icon": "$(refresh)"
			},
			{
				"command": "guideai.viewRunDetails",
				"title": "View Run Details"
			},
			{
				"command": "guideai.refreshComplianceTracker",
				"title": "Refresh Compliance Tracker",
				"icon": "$(refresh)"
			},
			{
				"command": "guideai.openComplianceReview",
				"title": "Open Compliance Review"
			},
			{
				"command": "guideai.createComplianceChecklist",
				"title": "Create Compliance Checklist"
			},
			{
				"command": "guideai.showOutput",
				"title": "Show Output"
			},
			{
				"command": "guideai.executionTracker.copyRunId",
				"title": "Copy Run ID"
			},
			{
				"command": "guideai.executionTracker.refreshRun",
				"title": "Refresh Run"
			},
			{
				"command": "guideai.complianceTracker.createChecklist",
				"title": "Create Checklist"
			},
			{
				"command": "guideai.complianceTracker.refreshChecklist",
				"title": "Refresh Checklist"
			},
			{
				"command": "guideai.mcp.showStatus",
				"title": "GuideAI: MCP Connection Status",
				"icon": "$(plug)"
			},
			{
				"command": "guideai.mcp.connect",
				"title": "GuideAI: Connect to MCP Server",
				"icon": "$(plug)"
			},
			{
				"command": "guideai.mcp.disconnect",
				"title": "GuideAI: Disconnect from MCP Server",
				"icon": "$(debug-disconnect)"
			},
			{
				"command": "guideai.openChat",
				"title": "GuideAI: Open Chat Panel",
				"icon": "$(comment-discussion)"
			},
			{
				"command": "guideai.refreshActionTracker",
				"title": "Refresh Action Registry",
				"icon": "$(refresh)"
			},
			{
				"command": "guideai.openActionTimeline",
				"title": "GuideAI: Open Action Timeline",
				"icon": "$(history)"
			},
			{
				"command": "guideai.recordAction",
				"title": "GuideAI: Record Action",
				"icon": "$(record)"
			},
			{
				"command": "guideai.listActions",
				"title": "GuideAI: List Actions"
			},
			{
				"command": "guideai.replayAction",
				"title": "GuideAI: Replay Action",
				"icon": "$(play)"
			},
			{
				"command": "guideai.viewActionDetail",
				"title": "View Action Details"
			},
			{
				"command": "guideai.actionTracker.copyActionId",
				"title": "Copy Action ID"
			},
			{
				"command": "guideai.actionTracker.filterByBehavior",
				"title": "Filter by Behavior"
			},
			{
				"command": "guideai.actionTracker.clearFilters",
				"title": "Clear Filters"
			},
			{
				"command": "guideai.refreshCostTracker",
				"title": "Refresh Cost Analytics",
				"icon": "$(refresh)"
			},
			{
				"command": "guideai.costTracker.setPeriod7d",
				"title": "Show Last 7 Days"
			},
			{
				"command": "guideai.costTracker.setPeriod30d",
				"title": "Show Last 30 Days"
			},
			{
				"command": "guideai.costTracker.setPeriod90d",
				"title": "Show Last 90 Days"
			},
			{
				"command": "guideai.openBehaviorAccuracy",
				"title": "GuideAI: Behavior Accuracy Dashboard",
				"icon": "$(graph)"
			},
			{
				"command": "guideai.openOnboarding",
				"title": "GuideAI: Set Up Workspace",
				"icon": "$(rocket)"
			},
			{
				"command": "guideai.submitBehaviorFeedback",
				"title": "GuideAI: Submit Behavior Feedback",
				"icon": "$(feedback)"
			},
			{
				"command": "guideai.refreshBehaviorAccuracy",
				"title": "Refresh Behavior Accuracy",
				"icon": "$(refresh)"
			},
			{
				"command": "guideai.openConversation",
				"title": "GuideAI: Open Conversation",
				"icon": "$(comment-discussion)"
			},
			{
				"command": "guideai.refreshConversations",
				"title": "Refresh Conversations",
				"icon": "$(refresh)"
			}
		],
		"menus": {
			"view/title": [
				{
					"command": "guideai.actionTracker.refresh",
					"when": "view == guideai.actionTracker",
					"group": "navigation"
				},
				{
					"command": "guideai.openActionTimeline",
					"when": "view == guideai.actionTracker",
					"group": "navigation"
				},
				{
					"command": "guideai.actionTracker.clearFilters",
					"when": "view == guideai.actionTracker",
					"group": "1_filters"
				},
				{
					"command": "guideai.refreshConversations",
					"when": "view == guideai.conversations",
					"group": "navigation"
				},
				{
					"command": "guideai.openConversation",
					"when": "view == guideai.conversations",
					"group": "navigation"
				},
				{
					"command": "guideai.refreshCostTracker",
					"when": "view == guideai.costTracker",
					"group": "navigation"
				},
				{
					"command": "guideai.costTracker.setPeriod7d",
					"when": "view == guideai.costTracker",
					"group": "1_period"
				},
				{
					"command": "guideai.costTracker.setPeriod30d",
					"when": "view == guideai.costTracker",
					"group": "1_period"
				},
				{
					"command": "guideai.costTracker.setPeriod90d",
					"when": "view == guideai.costTracker",
					"group": "1_period"
				}
			],
			"view/item/context": [
				{
					"command": "guideai.viewActionDetail",
					"when": "view == guideai.actionTracker && viewItem == action-item",
					"group": "inline"
				},
				{
					"command": "guideai.replayAction",
					"when": "view == guideai.actionTracker && viewItem == action-item",
					"group": "inline"
				},
				{
					"command": "guideai.actionTracker.copyActionId",
					"when": "view == guideai.actionTracker && viewItem == action-item",
					"group": "1_actions"
				},
				{
					"command": "guideai.actionTracker.filterByBehavior",
					"when": "view == guideai.actionTracker && viewItem == action-item",
					"group": "2_filters"
				}
			]
		},
		"viewItems": {
			"guideai.actionTracker": [
				{
					"id": "action-item",
					"name": "Action Item"
				},
				{
					"id": "status-group",
					"name": "Status Group"
				}
			],
			"guideai.executionTracker": [
				{
					"id": "run-item",
					"name": "Run Item"
				},
				{
					"id": "run-running",
					"name": "Running Run"
				},
				{
					"id": "run-completed",
					"name": "Completed Run"
				},
				{
					"id": "run-failed",
					"name": "Failed Run"
				},
				{
					"id": "run-cancelled",
					"name": "Cancelled Run"
				},
				{
					"id": "run-step",
					"name": "Run Step"
				},
				{
					"id": "run-step-pending",
					"name": "Pending Step"
				},
				{
					"id": "run-step-running",
					"name": "Running Step"
				},
				{
					"id": "run-step-completed",
					"name": "Completed Step"
				},
				{
					"id": "run-step-failed",
					"name": "Failed Step"
				}
			],
			"guideai.complianceTracker": [
				{
					"id": "checklist-draft",
					"name": "Draft Checklist"
				},
				{
					"id": "checklist-in-progress",
					"name": "In Progress Checklist"
				},
				{
					"id": "checklist-completed",
					"name": "Completed Checklist"
				},
				{
					"id": "checklist-approved",
					"name": "Approved Checklist"
				},
				{
					"id": "checklist-rejected",
					"name": "Rejected Checklist"
				},
				{
					"id": "step-pending",
					"name": "Pending Step"
				},
				{
					"id": "step-in-progress",
					"name": "In Progress Step"
				},
				{
					"id": "step-completed",
					"name": "Completed Step"
				},
				{
					"id": "step-blocked",
					"name": "Blocked Step"
				},
				{
					"id": "step-skipped",
					"name": "Skipped Step"
				},
				{
					"id": "comment",
					"name": "Comment"
				}
			]
		},
		"configuration": {
			"title": "GuideAI",
			"properties": {
				"guideai.pythonPath": {
					"type": "string",
					"default": "python",
					"description": "Path to Python executable for running the GuideAI CLI and MCP server"
				},
				"guideai.cliPath": {
					"type": "string",
					"default": "guideai",
					"description": "Path to the GuideAI CLI executable"
				},
				"guideai.mcpRequestTimeout": {
					"type": "number",
					"default": 30000,
					"minimum": 1000,
					"maximum": 300000,
					"description": "Timeout for individual MCP tool calls in milliseconds (default: 30 seconds)"
				},
				"guideai.mcpHeartbeatInterval": {
					"type": "number",
					"default": 30000,
					"minimum": 5000,
					"maximum": 120000,
					"description": "Interval between heartbeat pings to MCP server in milliseconds (default: 30 seconds)"
				},
				"guideai.mcpMaxReconnectAttempts": {
					"type": "number",
					"default": 10,
					"minimum": 0,
					"maximum": 100,
					"description": "Maximum number of automatic reconnection attempts before giving up (0 to disable)"
				},
				"guideai.mcpAutoReconnect": {
					"type": "boolean",
					"default": true,
					"description": "Automatically reconnect to MCP server when connection is lost"
				},
				"guideai.telemetryEnabled": {
					"type": "boolean",
					"default": true,
					"description": "Enable telemetry for usage analytics and diagnostics"
				},
				"guideai.telemetryActorId": {
					"type": "string",
					"default": "vscode-user",
					"description": "Actor ID for telemetry events"
				},
				"guideai.telemetryActorRole": {
					"type": "string",
					"default": "STUDENT",
					"enum": ["STUDENT", "TEACHER", "STRATEGIST"],
					"description": "Actor role for telemetry events"
				}
			}
		},
		"keybindings": [
			{
				"command": "guideai.openChat",
				"key": "ctrl+shift+g",
				"mac": "cmd+shift+g",
				"when": "editorTextFocus || !inputFocus"
			},
			{
				"command": "guideai.quickActions",
				"key": "ctrl+shift+alt+g",
				"mac": "cmd+shift+alt+g"
			},
			{
				"command": "guideai.openConversation",
				"key": "ctrl+shift+m",
				"mac": "cmd+shift+m",
				"when": "editorTextFocus || !inputFocus"
			}
		]
	},
	"scripts": {
		"vscode:prepublish": "tsc -p ./ || true",
		"compile": "tsc -p ./ || true",
		"watch": "tsc -watch -p ./",
		"pretest": "npm run compile && npm run lint",
		"lint": "eslint src --ext ts",
		"test": "node ./out/test/runTest.js",
		"package": "node scripts/package.js",
		"package:vsix": "vsce package",
		"publish": "vsce publish"
	},
	"devDependencies": {
		"@types/vscode": "^1.74.0",
		"@types/node": "16.x",
		"@types/mocha": "^10.0.6",
		"@types/glob": "^8.1.0",
		"@typescript-eslint/eslint-plugin": "^5.59.1",
		"@typescript-eslint/parser": "^5.59.1",
		"@vscode/test-electron": "^2.3.8",
		"@vscode/vsce": "^2.22.0",
		"eslint": "^10.1.0",
		"glob": "^8.1.0",
		"mocha": "^10.2.0",
		"typescript": "^5.0.4"
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.0.0"
	}
}
